---
import Layout from "@/layouts/Layout.astro";

const whatsappSteps = [
  {
    time: "7:30 AM",
    icon: "☀️",
    title: "Morning Briefing",
    body: "Rep wakes up to a WhatsApp message: today's meetings, prep notes for each prospect, a draft follow-up email, and a direct CRM link.",
    tags: ["Today's agenda", "Prospect prep", "Draft email", "CRM link"],
    color: "amber",
  },
  {
    time: "During the day",
    icon: "💬",
    title: "Post-meeting update",
    body: "Rep texts Mateos after each meeting. Notes are logged, CRM is updated, next steps are scheduled — all from WhatsApp.",
    tags: ["Text to log", "CRM auto-update", "Next steps set"],
    color: "teal",
  },
  {
    time: "End of day",
    icon: "✅",
    title: "Zero admin backlog",
    body: "~4 hours saved per rep per week. Every deal has a next action. You never drop the ball.",
    tags: ["4h saved / week", "Every deal tracked", "No missed follow-ups"],
    color: "indigo",
  },
];

const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2v4l-4-4H9a2 2 0 0 1-2-2v-1"/><path d="M15 6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2v4l4-4h2a2 2 0 0 0 2-2V6z"/></svg>`,
    title: "Come Prepared to Every Meeting",
    body: "Every rep gets a personalized briefing before each call — prospect history, last interaction, pain points, and a suggested approach.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: "No Deal Falls Between the Chairs",
    body: "Reps update Mateos by texting after meetings. Context stays current automatically. No deal goes cold because someone forgot to follow up.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Built for WhatsApp-First Markets",
    body: "WhatsApp is the #1 sales channel in our beachhead market. Most generic AI tools don't serve it. We do — natively, from day one.",
  },
];

const teamCredentials = [
  { label: "Google", color: "#4285F4" },
  { label: "Slack", color: "#4A154B" },
  { label: "MIT", color: "#A31F34" },
  { label: "UMass Boston", color: "#007A53" },
];
---

<Layout>
  <!-- ── NAVBAR ──────────────────────────────────────────────────────── -->
  <header>
    <div class="wrap bar">
      <a href="/" class="brand" aria-label="Mateos.ai home">
        <img src="/mateos-logo-secondary.svg" alt="Mateos.ai" class="brand-logo" />
      </a>

      <div class="nav-right">
        <nav class="nav-links">
          <a href="#product">Product</a>
          <a href="#team">Team</a>
        </nav>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <!-- Sun -->
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <!-- Moon -->
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <a href="mailto:david@mateos.ai" class="btn-cta">Request access</a>
      </div>
    </div>
  </header>

  <main>
    <!-- ── HERO ───────────────────────────────────────────────────────── -->
    <section class="hero" id="product">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="wrap hero-inner">
        <div class="hero-eyebrow">
          <svg width="18" height="18" viewBox="0 0 200 200" aria-hidden="true">
            <circle cx="130" cy="70" r="27" fill="#FF8C42"/>
            <circle cx="70" cy="130" r="27" fill="#17BEBB"/>
            <circle cx="130" cy="130" r="27" fill="#5B53E8"/>
          </svg>
          Sales Magician
        </div>
        <h1>You Never Miss a<br /><span class="gradient-text">Cold Lead Again</span></h1>
        <p class="hero-sub">
          Every morning, your rep gets a WhatsApp briefing: here's your day,
          here's prep for each meeting, here's a draft email, here's the CRM link.
        </p>
        <div class="hero-pills">
          <span class="pill">WhatsApp native</span>
          <span class="pill">CRM integrated</span>
          <span class="pill">Zero admin</span>
        </div>
        <div class="hero-actions">
          <a href="mailto:david@mateos.ai" class="btn-primary-lg">Get early access</a>
          <a href="#workflow" class="btn-ghost-lg">See how it works ↓</a>
        </div>
      </div>
    </section>

    <!-- ── FEATURES ───────────────────────────────────────────────────── -->
    <section class="features-section">
      <div class="wrap">
        <div class="features-grid">
          {features.map((f) => (
            <div class="feat-card">
              <div class="feat-icon" set:html={f.icon} />
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── WORKFLOW ────────────────────────────────────────────────────── -->
    <section class="workflow-section" id="workflow">
      <div class="wrap">
        <div class="section-header">
          <div class="eyebrow">A day in the life</div>
          <h2>Concrete workflow.<br />Real time savings.</h2>
          <p class="section-sub">
            See exactly how a rep's day looks when Mateos handles the admin.
          </p>
        </div>
        <div class="timeline">
          {whatsappSteps.map((step, i) => (
            <div class={`timeline-step step-${step.color}`}>
              <div class="step-marker">
                <span class="step-icon">{step.icon}</span>
                {i < whatsappSteps.length - 1 && <div class="step-line" />}
              </div>
              <div class="step-body">
                <div class="step-time">{step.time}</div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
                <div class="step-tags">
                  {step.tags.map((tag) => (
                    <span class={`tag tag-${step.color}`}>{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 24/7 AI OFFICER ────────────────────────────────────────────── -->
    <section class="coming-soon-section">
      <div class="wrap">
        <div class="coming-card">
          <div class="coming-badge">Coming soon</div>
          <h2>24/7 AI Officer</h2>
          <p>
            An always-on AI executive embedded in your business — monitoring
            pipelines, flagging risks, and acting before you need to ask.
          </p>
          <a href="mailto:david@mateos.ai" class="btn-outline-lg">
            Join the waitlist
          </a>
        </div>
      </div>
    </section>

    <!-- ── TEAM ───────────────────────────────────────────────────────── -->
    <section class="team-section" id="team">
      <div class="wrap">
        <div class="team-grid">
          <div class="team-left">
            <div class="eyebrow">The team</div>
            <h2>Built by people who've done it before</h2>
            <p>
              Our team comes from Google, Slack, MIT, and UMass Boston — with
              deep roots in AI research and enterprise software.
            </p>
            <div class="credential-badges">
              {teamCredentials.map((c) => (
                <span class="credential" style={`border-color:${c.color}22;color:${c.color}`}>
                  {c.label}
                </span>
              ))}
            </div>
          </div>
          <div class="team-right">
            <div class="stat-card">
              <div class="stat-number">3<span class="stat-plus">+</span></div>
              <div class="stat-label">years building AI solutions<br/>for SMBs</div>
            </div>
            <div class="stat-card stat-card-secondary">
              <div class="stat-number">∞</div>
              <div class="stat-label">domains served —<br/>we know your industry</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────────────── -->
    <section class="cta-section">
      <div class="wrap cta-inner">
        <h2>Ready to automate your sales ops?</h2>
        <p>Join the early access list. We'll reach out to set you up.</p>
        <a href="mailto:david@mateos.ai" class="btn-primary-lg">Get early access →</a>
      </div>
    </section>
  </main>

  <!-- ── FOOTER ─────────────────────────────────────────────────────── -->
  <footer>
    <div class="wrap footer-inner">
      <div class="brand" aria-label="Mateos.ai">
        <svg width="22" height="22" viewBox="43 43 114 114" aria-hidden="true">
          <circle cx="130" cy="70" r="27" fill="#FF8C42"/>
          <circle cx="70" cy="130" r="27" fill="#17BEBB"/>
          <circle cx="130" cy="130" r="27" fill="#5B53E8"/>
        </svg>
        <span class="brand-name">mateos<span class="brand-ai">.ai</span></span>
      </div>
      <span class="footer-copy">© 2026 Mateos AI · All rights reserved.</span>
    </div>
  </footer>
</Layout>

<style>
  /* ── Navbar ──────────────────────────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--nav-bg);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--nav-border);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
  }
  .brand-logo {
    height: 44px;
    width: auto;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .nav-links {
    display: none;
    gap: 24px;
  }
  @media (min-width: 640px) { .nav-links { display: flex; } }
  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text-primary); }
  .btn-cta {
    display: inline-block;
    background: var(--color-primary);
    color: var(--on-primary);
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .btn-cta:hover { background: var(--color-primary-hover); transform: translateY(-1px); }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--hero-bg);
    padding: 100px 0 90px;
    text-align: center;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(600px 400px at 70% 20%, rgba(255,140,66,0.45), transparent 65%),
      radial-gradient(500px 380px at 15% 85%, rgba(91,83,232,0.35), transparent 65%),
      radial-gradient(480px 340px at 90% 90%, rgba(23,190,187,0.25), transparent 65%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--amber-400);
    background: rgba(255, 140, 66, 0.12);
    border: 1px solid rgba(255, 140, 66, 0.3);
    padding: 10px 20px;
    border-radius: var(--radius-full);
  }
  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    color: #FFFFFF;
    line-height: 1.06;
    letter-spacing: -0.03em;
  }
  .gradient-text {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    max-width: 520px;
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.88);
  }
  .hero-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .pill {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.05);
    padding: 5px 12px;
    border-radius: var(--radius-full);
  }
  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }
  .btn-primary-lg {
    display: inline-block;
    background: var(--color-primary);
    color: var(--on-primary);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.75rem 1.6rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: var(--shadow-md);
  }
  .btn-primary-lg:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  .btn-ghost-lg {
    display: inline-block;
    font-size: 0.95rem;
    color: rgba(255,255,255,0.5);
    padding: 0.75rem 1.2rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255,255,255,0.12);
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost-lg:hover { color: rgba(255,255,255,0.85); border-color: rgba(255,255,255,0.3); }

  /* ── Features ────────────────────────────────────────────────────────── */
  .features-section {
    padding: 80px 0;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(3, 1fr); } }
  .feat-card {
    background: var(--surface-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .feat-card:hover {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-sm);
  }
  .feat-card:first-child { border-top: 3px solid var(--amber-500); }
  .feat-card:nth-child(2) { border-top: 3px solid var(--teal-500); }
  .feat-card:last-child { border-top: 3px solid var(--indigo-500); }
  .feat-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--color-primary-soft);
    color: var(--amber-600);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  [data-theme="dark"] .feat-icon { color: var(--amber-400); }
  .feat-card:nth-child(2) .feat-icon { background: var(--color-accent-soft); color: var(--teal-600); }
  [data-theme="dark"] .feat-card:nth-child(2) .feat-icon { color: var(--teal-400); }
  .feat-card:last-child .feat-icon { background: var(--color-secondary-soft); color: var(--indigo-600); }
  [data-theme="dark"] .feat-card:last-child .feat-icon { color: var(--indigo-400); }
  .feat-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .feat-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── Workflow ─────────────────────────────────────────────────────────── */
  .workflow-section {
    padding: 96px 0;
    background: var(--surface-subtle);
    border-bottom: 1px solid var(--border);
  }
  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 12px;
  }
  .section-sub {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .timeline {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .timeline-step {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 4px;
  }
  .step-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: var(--surface);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    z-index: 1;
    position: relative;
  }
  .step-amber .step-icon { border-color: var(--amber-400); background: var(--color-primary-soft); }
  .step-teal .step-icon  { border-color: var(--teal-400);  background: var(--color-accent-soft); }
  .step-indigo .step-icon { border-color: var(--indigo-400); background: var(--color-secondary-soft); }
  .step-line {
    width: 2px;
    flex: 1;
    min-height: 48px;
    background: var(--border);
    margin: 4px 0;
  }
  .step-body {
    padding-bottom: 48px;
    flex: 1;
  }
  .timeline-step:last-child .step-body { padding-bottom: 0; }
  .step-time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .step-body h3 {
    font-size: 1.15rem;
    margin-bottom: 8px;
  }
  .step-body p {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 14px;
  }
  .step-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: var(--radius-full);
  }
  .tag-amber { background: var(--color-primary-soft); color: var(--amber-700); }
  .tag-teal  { background: var(--color-accent-soft);  color: var(--teal-700); }
  .tag-indigo { background: var(--color-secondary-soft); color: var(--indigo-600); }
  [data-theme="dark"] .tag-amber { color: var(--amber-300); }
  [data-theme="dark"] .tag-teal  { color: var(--teal-300); }
  [data-theme="dark"] .tag-indigo { color: var(--indigo-300); }

  /* ── Coming soon ─────────────────────────────────────────────────────── */
  .coming-soon-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }
  .coming-card {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    background: var(--surface-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 56px 40px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .coming-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gradient-soft);
    opacity: 0.5;
    pointer-events: none;
  }
  .coming-card > * { position: relative; z-index: 1; }
  .coming-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--indigo-600);
    background: var(--color-secondary-soft);
    border: 1px solid var(--indigo-200);
    padding: 5px 14px;
    border-radius: var(--radius-full);
    display: inline-block;
  }
  [data-theme="dark"] .coming-badge {
    color: var(--indigo-300);
    border-color: var(--indigo-800);
  }
  .coming-card h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
  }
  .coming-card p {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 420px;
    line-height: 1.7;
  }
  .btn-outline-lg {
    display: inline-block;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-primary);
    color: var(--color-primary-text);
    transition: background 0.2s, transform 0.15s;
    margin-top: 4px;
  }
  .btn-outline-lg:hover {
    background: var(--color-primary-soft);
    transform: translateY(-1px);
  }
  [data-theme="dark"] .btn-outline-lg { color: var(--amber-400); }

  /* ── Team ────────────────────────────────────────────────────────────── */
  .team-section {
    padding: 96px 0;
    border-bottom: 1px solid var(--border);
  }
  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }
  @media (min-width: 768px) {
    .team-grid { grid-template-columns: 1fr 1fr; gap: 64px; }
  }
  .team-left { display: flex; flex-direction: column; gap: 20px; }
  .team-left h2 { font-size: clamp(1.6rem, 3.5vw, 2.25rem); }
