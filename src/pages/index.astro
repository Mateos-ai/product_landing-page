    .tl-step:nth-child(odd) .tl-points { justify-content: flex-end; }
    .tl-step:nth-child(even) .tl-card { grid-column: 3; grid-row: 1; }
  }

  /* ── Constellation ───────────────────────────────────────────────────── */
  .constellation { max-width: 920px; margin: 0 auto 56px; }
  .constellation svg { width: 100%; height: auto; overflow: visible; }

  .cst-line-base { stroke: var(--border-strong); stroke-width: 1.4; opacity: 0.5; fill: none; }
