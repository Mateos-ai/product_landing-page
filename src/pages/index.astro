---
import Layout from "@/layouts/Layout.astro";

// -- Card icons (lucide-style, inherit currentColor) -------------------------
const ICON = {
  megaphone: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`,
  shuffle: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>`,
  userX: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" y1="8" x2="22" y2="13"/><line x1="22" y1="8" x2="17" y2="13"/></svg>`,
  link: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
  focus: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/></svg>`,
  trending: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  search: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  layers: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
  barChart: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/></svg>`,
};

// -- Constellation data: input systems (left), knowledge-base core (center),
//    trusted agents with evals (right). Coordinates live in the SVG viewBox
//    "0 0 900 520" so the whole graphic scales as one unit.
const CORE = { x: 460, y: 260 };
const R_CORE = 62;
const TILE = 60;

const sources = [
  { name: "Gmail",           src: "/gmail.webp",      x: 90,  y: 70 },
  { name: "Slack",           src: "/slack.webp",      x: 250, y: 95 },
  { name: "Zendesk",         src: "/zendesk.webp",    x: 70,  y: 200 },
  { name: "Datadog",         src: "/datadog.webp",    x: 235, y: 210 },
  { name: "HubSpot",         src: "/hubspot.webp",    x: 95,  y: 320 },
  { name: "Notion",          src: "/notion.webp",     x: 255, y: 330 },
  { name: "Salesforce",      src: "/salesforce.webp", x: 100, y: 440 },
  { name: "Google Calendar", src: "/gcalendar.webp",  x: 255, y: 445 },
];

const agents = [
  {
    label: "Support agent",
    x: 745, y: 130,
    icons: ["/zendesk.webp", "/notion.webp", "/gmail.webp"],
  },
  {
    label: "Revenue agent",
    x: 785, y: 260,
    icons: ["/salesforce.webp", "/hubspot.webp", "/gcalendar.webp"],
  },
  {
    label: "Ops agent",
    x: 745, y: 390,
    icons: ["/slack.webp", "/datadog.webp", "/notion.webp"],
  },
];

const problems = [
  {
    icon: ICON.megaphone,
    title: "Endless pitches",
    body: "Vendors pitch you tools you're not sure you need.",
  },
  {
    icon: ICON.shuffle,
    title: "Scattered experiments",
    body: "Your team is experimenting, but nothing's tied to the P&L.",
  },
  {
    icon: ICON.userX,
    title: "No one to own it",
    body: "You can't justify a $400k Chief AI Officer to sort it out.",
  },
];

const payoffs = [
  {
    icon: ICON.link,
    title: "Everything in one place",
    body: "Your tools stop living on separate islands. What used to mean five tabs and a copy-paste happens once, in one flow.",
  },
  {
    icon: ICON.focus,
    title: "Your team does what only they can",
    body: "The repetitive work runs itself, so your people spend their day on judgment and relationships, not admin.",
  },
  {
    icon: ICON.trending,
    title: "Wins that compound",
    body: "Not a big-bang transformation. A first win in weeks, then the next, then the next.",
  },
];

const process = [
  {
    num: "01",
    color: "teal",
    icon: ICON.search,
    title: "Diagnose",
    body: "We sit with your C-suite, VPs, and teams, map your workflows and data, and rank the AI opportunities by real ROI. You walk away with a prioritized roadmap you own, whether or not you build it with us.",
    points: ["Sit with your people", "Map workflows & data", "Rank by ROI, effort & fit"],
  },
  {
    num: "02",
    color: "purple",
    icon: ICON.layers,
    title: "Build what matters",
    body: "We build only what earns its place, starting with the highest-impact win. We have no product of our own to push, so we pick whatever actually fits, within the budget we agreed on.",
    points: ["Off-the-shelf", "Custom", "Hybrid"],
  },
  {
    num: "03",
    color: "amber",
    icon: ICON.barChart,
    title: "Measure",
    body: "Every agent ships with an accuracy score so you can see how well it performs and the payoff you were promised. We prove the win with numbers, then move to the next one.",
    points: ["Accuracy on every agent", "Track the ROI", "Then the next win"],
  },
];

const pillars = [
  {
    color: "teal",
    title: "Connect your stack",
    body: "Gmail, Slack, Zendesk, Datadog, your CRM, your docs. The tools you already run, wired together.",
  },
  {
    color: "purple",
    title: "One knowledge base",
    body: "Scattered data becomes a single source of truth your agents can actually reason over.",
  },
  {
    color: "amber",
    title: "Agents that learn",
    body: "Not brittle automations. They adapt as your business changes.",
  },
];

---

<Layout
  title="Mateos · Your outsourced Chief AI Officer"
  description="Mateos is the outsourced Chief AI Officer for SMBs. We start with a diagnostic, find where AI actually moves your numbers, then build only what earns its place."
>
  <!-- ── NAVBAR ──────────────────────────────────────────────────────── -->
  <header>
    <div class="wrap bar">
      <a href="#top" class="brand" aria-label="Mateos.ai home">
        <img src="/mateos-logo.svg" alt="" class="brand-mark" />
        <span class="brand-name">mateos<span class="brand-ai">.ai</span></span>
      </a>

      <div class="nav-right">
        <a href="#cta" class="btn-cta">Book a Diagnostic</a>
        <div class="theme-picker" id="theme-picker">
          <button class="theme-trigger" id="theme-trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Color theme">
            <span class="theme-icon" id="theme-icon"></span>
          </button>
          <ul class="theme-dropdown" role="listbox" id="theme-dropdown">
            <li class="theme-opt" role="option" data-value="system">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              System
            </li>
            <li class="theme-opt" role="option" data-value="light">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
              Light
            </li>
            <li class="theme-opt" role="option" data-value="dark">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              Dark
            </li>
          </ul>
        </div>
      </div>
    </div>
  </header>

  <main>
    <!-- ── HERO ───────────────────────────────────────────────────────── -->
    <section class="hero" id="top">
      <div class="wrap hero-inner">
        <img src="/mateos-logo-secondary.svg" alt="" class="hero-logo" />
        <h1><span class="gradient-text">Your Chief AI Officer</span></h1>
        <p class="hero-tagline"><span class="hl-orange">AI hype</span> is everywhere, and the fear of <span class="hl-teal">falling behind</span> is even louder. <span class="hl-purple">We cut through the noise</span>, find where AI actually pays off for your business, and build exactly that.</p>
        <div class="hero-actions">
          <a href="#problem" class="btn-ghost-lg btn-magic">See how it works ↓</a>
        </div>
      </div>
    </section>

    <!-- ── PROBLEM ────────────────────────────────────────────────────── -->
    <section class="section" id="problem">
      <div class="wrap">
        <div class="section-head" data-reveal>
          <div class="eyebrow">The AI moment</div>
          <h2><span class="hl-orange">You're not behind.</span><br />You're missing a translator.</h2>
          <p class="section-lead">Every week there's a new agent, a new tool, a new reason you're "falling behind." Half of it is hype. Some could genuinely change your business. And you have no one whose only job is to tell you which is which.</p>
        </div>
        <div class="card-grid card-grid-3">
          {problems.map((p, i) => (
            <div class="card card-orange" data-reveal data-reveal-delay={i + 1}>
              <div class="card-icon" set:html={p.icon} />
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── PAYOFF ─────────────────────────────────────────────────────── -->
    <section class="section section-alt" id="payoff">
      <div class="wrap">
        <div class="section-head" data-reveal>
          <div class="eyebrow eyebrow-teal">The payoff</div>
          <h2>The busywork disappears.<br /><span class="hl-teal">The wins compound.</span></h2>
          <p class="section-lead">No AI transformation, no product we're pushing. Just the specific wins that move your numbers, wired together so your whole company feels it.</p>
        </div>
        <div class="card-grid card-grid-3">
          {payoffs.map((p, i) => (
            <div class="card card-teal" data-reveal data-reveal-delay={i + 1}>
              <div class="card-icon" set:html={p.icon} />
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── HOW IT WORKS (diagnose → build → measure timeline) ─────────── -->
    <section class="section" id="process">
      <div class="wrap">
        <div class="section-head" data-reveal>
          <div class="eyebrow eyebrow-purple">How it works</div>
          <h2>We find it. We build it. We prove it.<br /><span class="hl-purple">No hype, no guesswork.</span></h2>
          <p class="section-lead">A clear path from "we should probably do AI" to results you can put a number on.</p>
        </div>
        <div class="timeline">
          {process.map((s, i) => (
            <div class={`tl-step step-${s.color}`} data-reveal>
              <div class="tl-marker">
                <span class="tl-icon" set:html={s.icon} />
              </div>
              <div class="tl-card">
                <span class="tl-num">Step {s.num}</span>
                <h3>{s.title}</h3>
                <p>{s.body}</p>
                <ul class="tl-points">
                  {s.points.map((pt) => (
                    <li>{pt}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── HOW WE BUILD (constellation) ───────────────────────────────── -->
    <section class="section section-alt" id="how">
      <div class="wrap">
        <div class="section-head" data-reveal>
          <div class="eyebrow">How we build</div>
          <h2><span class="gradient-text">We connect everything.</span><br />Then we make it think.</h2>
          <p class="section-lead">The diagnostic tells you what's worth building. This is how we build it.</p>
        </div>

        <div class="constellation" data-reveal>
          <svg viewBox="0 0 900 520" role="img" aria-label="Your systems connect into one unified knowledge base that powers trusted agents, each with evals.">
            <defs>
              <filter id="cstShadow" x="-40%" y="-40%" width="180%" height="180%">
                <feDropShadow dx="0" dy="3" stdDeviation="6" flood-color="#14141e" flood-opacity="0.14" />
              </filter>
              <!-- brand gradient for the brain at the core (teal → purple → orange) -->
              <linearGradient id="cstBrain" gradientUnits="userSpaceOnUse" x1="3" y1="4" x2="21" y2="20">
                <stop offset="0" stop-color="#17BEBB" />
                <stop offset="0.5" stop-color="#5B53E8" />
                <stop offset="1" stop-color="#FF8C42" />
              </linearGradient>
            </defs>

            <!-- connectors: systems -> core -->
            {sources.map((s, i) => (
              <>
                <line class="cst-line-base" x1={s.x} y1={s.y} x2={CORE.x} y2={CORE.y} />
                <line class="cst-line-flow" x1={s.x} y1={s.y} x2={CORE.x} y2={CORE.y} style={`animation-delay:${(i * 0.13).toFixed(2)}s`} />
              </>
            ))}

            <!-- connectors: core -> agents -->
            {agents.map((a, i) => (
              <>
                <line class="cst-line-base" x1={CORE.x} y1={CORE.y} x2={a.x} y2={a.y} />
                <line class="cst-line-flow out" x1={CORE.x} y1={CORE.y} x2={a.x} y2={a.y} style={`animation-delay:${(i * 0.2).toFixed(2)}s`} />
              </>
            ))}

            <!-- core glow -->
            <circle class="cst-core-glow" cx={CORE.x} cy={CORE.y} r={R_CORE} />

            <!-- system tiles -->
            {sources.map((s) => (
              <g filter="url(#cstShadow)">
                <rect class="cst-tile" x={s.x - TILE / 2} y={s.y - TILE / 2} width={TILE} height={TILE} rx="14" />
                <image href={s.src} x={s.x - TILE / 2 + 11} y={s.y - TILE / 2 + 11} width={TILE - 22} height={TILE - 22} preserveAspectRatio="xMidYMid meet" />
              </g>
            ))}

            <!-- core: the client's unified brain -->
            <g filter="url(#cstShadow)">
              <circle class="cst-core" cx={CORE.x} cy={CORE.y} r={R_CORE} />
              <svg x={CORE.x - 31} y={CORE.y - 31} width="62" height="62" viewBox="0 0 24 24"
                   fill="none" stroke="url(#cstBrain)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z" />
                <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1 .556 6.588A4 4 0 1 1 12 18Z" />
                <path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4" />
                <path d="M17.599 6.5a3 3 0 0 0 .399-1.375" />
                <path d="M6.003 5.125A3 3 0 0 0 6.401 6.5" />
                <path d="M3.477 10.896a4 4 0 0 1 .585-.396" />
                <path d="M19.938 10.5a4 4 0 0 1 .585.396" />
                <path d="M6 18a4 4 0 0 1-1.967-.516" />
                <path d="M19.967 17.484A4 4 0 0 1 18 18" />
              </svg>
            </g>
            <text class="cst-core-label" x={CORE.x} y={CORE.y + R_CORE + 24} text-anchor="middle">Unified knowledge base</text>

            <!-- agents with evals -->
            {agents.map((a) => {
              const w = 176;
              const h = 60;
              const lx = a.x - w / 2;
              const ly = a.y - h / 2;
              const iSize = 18;
              const iGap = 6;
              const iX = lx + 18;
              const iY = a.y + 3;
              return (
                <g filter="url(#cstShadow)">
                  <rect class="cst-agent" x={lx} y={ly} width={w} height={h} rx="14" />
                  <circle class="cst-agent-live" cx={lx + 18} cy={a.y - 12} r="4" />
                  <text class="cst-agent-label" x={lx + 32} y={a.y - 8}>{a.label}</text>
                  {a.icons.map((src, i) => (
                    <image class="cst-agent-icon" href={src} x={iX + i * (iSize + iGap)} y={iY} width={iSize} height={iSize} preserveAspectRatio="xMidYMid meet" />
                  ))}
                </g>
              );
            })}
          </svg>
        </div>

        <div class="card-grid card-grid-3 how-grid">
          {pillars.map((p, i) => (
            <div class={`card pill-${p.color}`} data-reveal data-reveal-delay={i + 1}>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────────────── -->
    <section class="cta-section" id="cta">
      <div class="wrap cta-inner" data-reveal>
        <h2><span class="gradient-text">Find out where AI pays off for you.</span></h2>
        <p>Book a fixed-scope diagnostic. Walk away with a roadmap and the numbers, whether or not you build with us.</p>
        <form class="early-form" id="form-cta" novalidate>
          <input type="email" class="early-input" placeholder="your@email.com" required autocomplete="email" />
          <button type="submit" class="btn-primary-lg">Book a Diagnostic →</button>
        </form>
        <p class="early-success" id="success-cta" hidden>Thanks. We'll be in touch to schedule your diagnostic.</p>
      </div>
    </section>
  </main>

  <!-- ── FOOTER ─────────────────────────────────────────────────────── -->
  <footer>
    <div class="wrap footer-inner">
      <div class="brand" aria-label="Mateos.ai">
        <svg width="22" height="22" viewBox="43 43 114 114" aria-hidden="true">
          <circle cx="130" cy="70" r="27" fill="#FF8C42" />
          <circle cx="70" cy="130" r="27" fill="#17BEBB" />
          <circle cx="130" cy="130" r="27" fill="#5B53E8" />
        </svg>
        <span class="brand-name">mateos<span class="brand-ai">.ai</span></span>
      </div>
      <span class="footer-copy">2026 · © Mateos · All rights reserved.</span>
    </div>
  </footer>
</Layout>

<style>
  /* ── Navbar ──────────────────────────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--nav-bg);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--nav-border);
  }
  .bar { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .brand { display: flex; align-items: center; gap: 10px; }
  .brand-mark { height: 28px; width: auto; }
  .brand-name { font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; color: var(--text-primary); letter-spacing: -0.01em; }
  .brand-ai { color: var(--amber-500); }
  .nav-right { display: flex; align-items: center; gap: 16px; }
  .nav-link { font-size: 0.875rem; font-weight: 500; color: var(--text-secondary); transition: color 0.15s; }
  .nav-link:hover { color: var(--text-primary); }
  @media (max-width: 640px) { .nav-link { display: none; } }
  .btn-cta {
    display: inline-block;
    background: var(--color-primary);
    color: var(--on-primary);
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .btn-cta:hover { background: var(--color-primary-hover); transform: translateY(-1px); }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--hero-bg);
    min-height: 92vh;
    text-align: center;
    display: flex;
    align-items: center;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .hero-logo { height: 64px; width: auto; margin-bottom: 4px; }
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary-text);
    border: 1px solid var(--hero-pill-border);
    background: var(--hero-pill-bg);
    padding: 6px 14px;
    border-radius: var(--radius-full);
  }
  :global([data-theme="dark"]) .hero-eyebrow { color: var(--amber-400); }
  .hero h1 {
    font-size: clamp(2.5rem, 6.5vw, 4.75rem);
    color: var(--hero-heading);
    line-height: 1.04;
    letter-spacing: -0.03em;
  }
  .hero-tagline {
    max-width: 620px;
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    font-weight: 500;
    color: var(--hero-body);
