---
import Layout from "@/layouts/Layout.astro";

const ICON = {
  sun: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
  message: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  search: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  zap: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  repeat: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>`,
};

const justAskSteps = [
  {
    icon: ICON.search,
    title: "Ask Anything",
    tags: ["Rank my top 10 leads by deal size and last contact", "What are the 3 main reasons we lost deals last quarter?", "Which accounts haven't heard from us in 30+ days?"],
    color: "amber",
  },
  {
    icon: ICON.zap,
    title: "Takes Action",
    tags: ["Block 30 min tomorrow to prep for my Acme call", "Send a follow-up to Sarah at Notion, reference our last call"],
    color: "teal",
  },
  {
    icon: ICON.repeat,
    title: "Autopilot",
    tags: ["Always remind me to follow up 3 days after a first meeting", "Flag any deal with no activity in 2 weeks"],
    color: "indigo",
  },
];

const whatsappSteps = [
  {
    time: "7:30 AM",
    icon: ICON.sun,
    title: "Morning Briefing",
    tags: ["Today's agenda", "Prospect prep", "Draft email"],
    color: "amber",
  },
  {
    time: "During the day",
    icon: ICON.message,
    title: "Post-meeting update",
    tags: ["Auto CRM sync", "To-do list updated", "WhatsApp or email"],
    color: "teal",
  },
  {
    time: "End of day",
    icon: ICON.check,
    title: "Zero admin backlog",
    tags: ["Real-time updates", "Rep chooses the channel", "Nothing falls through"],
    color: "indigo",
  },
];

const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2v4l-4-4H9a2 2 0 0 1-2-2v-1"/><path d="M15 6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2v4l4-4h2a2 2 0 0 0 2-2V6z"/></svg>`,
    title: "Come Prepared to Every Meeting",
    body: `Every rep gets a <span class="brand-text">personalized briefing</span> before each call: prospect history, last interaction, pain points, and a suggested approach.`,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: "No Deal Falls Between the Chairs",
    body: `Reps update <span class="brand-text">Mateos</span> by texting after meetings. Context stays current automatically. <span class="brand-text">No deal goes cold</span> because someone forgot to follow up.`,
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Available Where You Live",
    body: `<span class="brand-text">WhatsApp, email, or web</span>. Talk to your agent the way you already work. <span class="brand-text">No new apps</span>, no behavior change.`,
  },
];

const integrations = [
  { name: "WhatsApp",        src: "/whatsapp.svg" },
  { name: "HubSpot",         src: "/hubspot.webp" },
  { name: "Notion",          src: "/notion.webp" },
  { name: "Zendesk",         src: "/zendesk.webp" },
  { name: "Salesforce",      src: "/salesforce.webp" },
  { name: "Monday",          src: "/monday.webp" },
  { name: "ClickUp",         src: "/clickup.webp" },
  { name: "Todoist",         src: "/todoist.webp" },
  { name: "Gmail",           src: "/gmail.webp" },
  { name: "Google Calendar", src: "/gcalendar.webp" },
  { name: "Outlook",         src: "/outlook.webp" },
];

const teamLogos = [
  {
    label: "Google",
    svg: `<svg width="100" height="100" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
    </svg>`,
  },
  {
    label: "MIT",
    svg: `<svg width="160" height="100" viewBox="0 0 160 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <text x="80" y="62" font-family="Georgia,serif" font-weight="700" font-size="52" fill="#A31F34" text-anchor="middle">MIT</text>
    </svg>`,
  },
  {
    label: "Slack",
    svg: `<svg width="100" height="100" viewBox="0 0 127 127" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M27.2 80c0 7.3-5.9 13.2-13.2 13.2C6.7 93.2.8 87.3.8 80c0-7.3 5.9-13.2 13.2-13.2h13.2V80z" fill="#E01E5A"/>
      <path d="M33.8 80c0-7.3 5.9-13.2 13.2-13.2 7.3 0 13.2 5.9 13.2 13.2v33c0 7.3-5.9 13.2-13.2 13.2-7.3 0-13.2-5.9-13.2-13.2V80z" fill="#E01E5A"/>
      <path d="M47 27c-7.3 0-13.2-5.9-13.2-13.2C33.8 6.5 39.7.6 47 .6c7.3 0 13.2 5.9 13.2 13.2V27H47z" fill="#36C5F0"/>
      <path d="M47 33.8c7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2H14c-7.3 0-13.2-5.9-13.2-13.2 0-7.3 5.9-13.2 13.2-13.2h33z" fill="#36C5F0"/>
      <path d="M100 47c0-7.3 5.9-13.2 13.2-13.2 7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2H100V47z" fill="#2EB67D"/>
      <path d="M93.4 47c0 7.3-5.9 13.2-13.2 13.2-7.3 0-13.2-5.9-13.2-13.2V14c0-7.3 5.9-13.2 13.2-13.2 7.3 0 13.2 5.9 13.2 13.2v33z" fill="#2EB67D"/>
      <path d="M80.2 100c7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2-7.3 0-13.2-5.9-13.2-13.2V100h13.2z" fill="#ECB22E"/>
      <path d="M80.2 93.4c-7.3 0-13.2-5.9-13.2-13.2 0-7.3 5.9-13.2 13.2-13.2H113c7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2H80.2z" fill="#ECB22E"/>
    </svg>`,
  },
];
---

<Layout>
  <!-- ── NAVBAR ──────────────────────────────────────────────────────── -->
  <header>
    <div class="wrap bar">
      <a href="/" class="brand" aria-label="Mateos.ai home">
        <img src="/mateos-logo.svg" alt="" class="brand-mark" />
        <span class="brand-name">mateos<span class="brand-ai">.ai</span></span>
      </a>

      <div class="nav-right">
        <nav class="nav-links" id="nav-links">
          <a href="#workflow">Workflows</a>
          <a href="#just-ask">Actions</a>
          <a href="#integrations">Integrations</a>
          <a href="#agents">Embeddings</a>
          <a href="#team">Team</a>
        </nav>
        <a href="#cta" class="btn-cta">Get Early Access</a>
        <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <div class="theme-picker" id="theme-picker">
          <button class="theme-trigger" id="theme-trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Color theme">
            <span class="theme-icon" id="theme-icon"></span>
          </button>
          <ul class="theme-dropdown" role="listbox" id="theme-dropdown">
            <li class="theme-opt" role="option" data-value="system">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              System
            </li>
            <li class="theme-opt" role="option" data-value="light">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
              Light
            </li>
            <li class="theme-opt" role="option" data-value="dark">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              Dark
            </li>
          </ul>
        </div>
      </div>
    </div>
  </header>

  <main>
    <!-- ── HERO ───────────────────────────────────────────────────────── -->
    <section class="hero" id="product">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="wrap hero-inner">
        <img src="/mateos-logo-secondary.svg" alt="" class="hero-logo" />
        <h1><span class="brand-text">Mateos'</span><br /><span class="gradient-text">Sales Magician</span></h1>
        <p class="hero-tagline">The perfect assistant, every step of the funnel.</p>
        <div class="hero-actions">
          <a href="#imagine" class="btn-ghost-lg btn-ghost-animated">See The Magic ↓</a>
        </div>
      </div>
    </section>

    <!-- ── IMAGINE ──────────────────────────────────────────────────────── -->
    <section class="imagine-section" id="imagine">
      <div class="wrap imagine-inner">
        <p class="imagine-eyebrow">Imagine</p>
        <p class="imagine-intro" id="imagine-intro"><span class="tw-cursor">|</span></p>
        <div class="imagine-lines" id="imagine-lines">
          <p class="imagine-line imagine-line-hidden" set:html={`Pipeline <span class="imagine-hl">sorted.</span>`} />
          <p class="imagine-line imagine-line-hidden" set:html={`Drafts <span class="imagine-hl">ready.</span>`} />
          <p class="imagine-line imagine-line-hidden" set:html={`Ghosters <span class="imagine-hl">flagged.</span>`} />
          <p class="imagine-line imagine-line-hidden" set:html={`Upsells <span class="imagine-hl">surfaced.</span>`} />
        </div>
      </div>
    </section>

    <!-- ── WORKFLOW ────────────────────────────────────────────────────── -->
    <section class="workflow-section" id="workflow">
      <div class="wrap">
        <div class="section-header" data-reveal>
          <h2>It Builds Your Workflow...</h2>
        </div>
        <div class="timeline">
          {whatsappSteps.map((step, i) => (
            <div class={`timeline-step step-${step.color}`} data-reveal data-reveal-delay={i}>
              <div class="step-marker">
                <span class="step-icon" set:html={step.icon} />
                {i < whatsappSteps.length - 1 && <div class="step-line" />}
              </div>
              <div class="step-body">
                <div class="step-time">{step.time}</div>
                <h3>{step.title}</h3>
                <div class="step-tags">
                  {step.tags.map((tag) => (
                    <span class={`tag tag-${step.color}`}>{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ── JUST ASK ──────────────────────────────────────────────────────── -->
    <section class="workflow-section" id="just-ask">
      <div class="wrap">
        <div class="section-header" data-reveal>
          <h2>...And Takes Action</h2>
        </div>
        <div class="timeline">
          {justAskSteps.map((step, i) => (
            <div class={`timeline-step step-${step.color}`} data-reveal data-reveal-delay={i}>
              <div class="step-marker">
                <span class="step-icon" set:html={step.icon} />
                {i < justAskSteps.length - 1 && <div class="step-line" />}
              </div>
              <div class="step-body">
                <h3>{step.title}</h3>
                <div class="step-tags">
                  {step.tags.map((tag) => (
                    <span class={`tag tag-${step.color}`}>"{tag}"</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── INTEGRATIONS ──────────────────────────────────────────────── -->
    <section class="integrations-section" id="integrations">
      <div class="wrap">
        <div class="section-header" data-reveal>
          <div class="eyebrow">Integrations</div>
          <h2>It Works With Your Stack...</h2>
        </div>
        <div class="carousel-track">
          <div class="carousel-inner" aria-hidden="false">
            {[...integrations, ...integrations].map((i, idx) => (
              <img
                src={i.src}
                alt={i.name}
                class="carousel-logo"
                aria-label={idx < integrations.length ? i.name : undefined}
              />
            ))}
          </div>
        </div>
      </div>
    </section>



    <!-- ── TEAM ───────────────────────────────────────────────────────── -->
    <section class="team-section" id="team">
      <div class="wrap">
        <div class="team-grid">
          <div class="section-header" data-reveal>
            <div class="eyebrow">The team</div>
            <h2>...And We've Done It Before</h2>
            <p>
              Our team comes from <span class="brand-text">Google</span>, <span class="brand-text">Slack</span>, and <span class="brand-text">MIT</span>, with
              deep roots in <span class="brand-text">AI research</span> and <span class="brand-text">enterprise software</span>.
            </p>
            <div class="credential-row">
              {teamLogos.map((c) => (
                <span class="credential-logo" title={c.label} set:html={c.svg} />
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 24/7 AI OFFICER ────────────────────────────────────────────── -->
    <section class="coming-soon-section" id="agents">
      <div class="wrap">
        <div class="coming-card" data-reveal>
          <div class="coming-badge">Coming soon</div>
          <h2 class="coming-title">24/7 AI Officer</h2>
          <p>
            An <span class="brand-text">always-on</span> AI executive <span class="brand-text">embedded</span> in your business: <span class="brand-text">monitoring</span>
            pipelines, <span class="brand-text">flagging</span> risks, and <span class="brand-text">acting before</span> you need to ask.
          </p>
          <a href="mailto:david@mateos.ai" class="btn-outline-lg">
            Join the waitlist
          </a>
        </div>
      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────────────── -->
    <section class="cta-section" id="cta">
      <div class="wrap cta-inner" data-reveal>
        <h2><span class="brand-text">10X Boost</span> Your <span class="brand-text">Sales </span>Reps</h2>
        <p><span class="brand-text">Join early access.</span> We'll reach out to set you up.</p>
        <form class="early-form" id="form-cta" novalidate>
          <input type="email" class="early-input" placeholder="your@email.com" required autocomplete="email" />
          <button type="submit" class="btn-primary-lg">Get early access →</button>
        </form>
        <p class="early-success" id="success-cta" hidden>Thank you for joining the waitlist!</p>
      </div>
    </section>
  </main>

  <!-- ── FOOTER ─────────────────────────────────────────────────────── -->
  <footer>
    <div class="wrap footer-inner">
      <div class="brand" aria-label="Mateos.ai">
        <svg width="22" height="22" viewBox="43 43 114 114" aria-hidden="true">
          <circle cx="130" cy="70" r="27" fill="#FF8C42"/>
          <circle cx="70" cy="130" r="27" fill="#17BEBB"/>
          <circle cx="130" cy="130" r="27" fill="#5B53E8"/>
        </svg>
        <span class="brand-name">mateos<span class="brand-ai">.ai</span></span>
      </div>
      <span class="footer-copy">2026 · © Mateos · All rights reserved.</span>
    </div>
  </footer>
</Layout>

<style>
  /* ── Navbar ──────────────────────────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--nav-bg);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--nav-border);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .brand-mark {
    height: 28px;
    width: auto;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  @media (min-width: 1024px) { .nav-right .btn-cta { margin-left: 20px; } }
  .nav-links {
    display: none;
    gap: 24px;
  }
  @media (min-width: 1024px) { .nav-links { display: flex; } }
  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--amber-500); }

  /* Burger */
  .burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px;
    flex-shrink: 0;
  }
  .burger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
    transform-origin: center;
  }
  .burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger.is-open span:nth-child(2) { opacity: 0; }
  .burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  @media (min-width: 1024px) { .burger { display: none; } }

  /* Mobile nav drawer */
  .nav-links.is-open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 64px;
    left: 0;
    right: 0;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 20px 24px;
    gap: 0;
    z-index: 99;
  }
  .nav-links.is-open a {
    padding: 14px 0;
    font-size: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .nav-links.is-open a:last-child { border-bottom: none; }
  .btn-cta {
    display: inline-block;
    background: var(--color-primary);
    color: var(--on-primary);
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .btn-cta:hover { background: var(--color-primary-hover); transform: translateY(-1px); }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--hero-bg);
    min-height: 100vh;
    padding: 0;
    text-align: center;
    display: flex;
    align-items: center;
  }
  .hero-glow { display: none; }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .hero-logo {
    height: 72px;
    width: auto;
    margin-bottom: 8px;
  }
  .hero h1 {
    font-size: clamp(3rem, 8vw, 5.5rem);
    color: var(--hero-heading);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 600;
    color: var(--hero-body);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .gradient-text {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    max-width: 520px;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--hero-body);
  }
  .hero-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .pill {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--hero-pill-text);
    border: 1px solid var(--hero-pill-border);
    background: var(--hero-pill-bg);
    padding: 5px 12px;
    border-radius: var(--radius-full);
  }
  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    margin-top: 8px;
  }
  .early-form {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .early-input {
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 0.95rem;
    width: 220px;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }
  .early-input:focus {
    border-color: var(--amber-500);
    box-shadow: 0 0 0 3px rgba(255,140,66,0.15);
  }
  .early-input::placeholder { color: var(--text-muted); }
  .early-success {
    font-size: 0.95rem;
    color: var(--teal-600);
    font-weight: 500;
    margin-top: 4px;
  }
  :global([data-theme="dark"]) .early-success { color: var(--teal-400); }
  .btn-primary-lg {
    display: inline-block;
    background: var(--color-primary);
    color: var(--on-primary);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.75rem 1.6rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: var(--shadow-md);
  }
  .btn-primary-lg:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  .btn-primary-lg.is-success {
    background: transparent;
    box-shadow: none;
    border: 2px solid #22c55e;
    color: #22c55e;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    padding: 0;
    pointer-events: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    animation: success-pop 0.4s cubic-bezier(0.34,1.56,0.64,1);
  }
  @keyframes success-pop {
    0%   { transform: scale(0.8); }
    100% { transform: scale(1); }
  }
  .btn-ghost-lg {
    display: inline-block;
    font-size: 0.95rem;
    color: var(--hero-ghost-text);
    padding: 0.75rem 1.2rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--hero-ghost-border);
    transition: border-color 0.3s, color 0.3s;
    position: relative;
    z-index: 0;
  }
  .btn-ghost-lg::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: calc(var(--radius-sm) + 1px);
    padding: 1px;
    background: linear-gradient(90deg, var(--amber-500), var(--teal-500), var(--indigo-500), var(--amber-500));
    background-size: 300% 100%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s;
    z-index: -1;
  }
  .btn-ghost-lg:hover {
    border-color: transparent;
    background: linear-gradient(90deg, var(--amber-500), var(--teal-500), var(--indigo-500), var(--amber-500));
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: magic-gradient 2s linear infinite;
  }
  .btn-ghost-lg:hover::before {
    opacity: 1;
    animation: magic-gradient 2s linear infinite;
  }
  @keyframes magic-gradient {
    0%   { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }
  :global([data-theme="dark"]) .btn-ghost-lg { color: #FFFFFF; border-color: rgba(255,255,255,0.6); }
  :global([data-theme="dark"]) .btn-ghost-lg:hover { -webkit-text-fill-color: transparent; }
  .btn-ghost-animated {
    border-color: transparent !important;
    background: linear-gradient(90deg, var(--amber-500), var(--teal-500), var(--indigo-500), var(--amber-500));
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: magic-gradient 2s linear infinite;
  }
  .btn-ghost-animated::before {
    opacity: 1 !important;
    animation: magic-gradient 2s linear infinite !important;
  }

  /* ── Imagine ─────────────────────────────────────────────────────────── */
  .imagine-section {
    background: var(--neutral-900);
    padding: 80px 0;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }
  .imagine-inner {
    max-width: 760px;
    width: 100%;
  }
  .imagine-eyebrow {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--amber-400);
    margin-bottom: 48px;
  }
  .imagine-line-hidden {
    opacity: 0;
    transform: translateY(24px) scale(0.98);
    transition: opacity 0.6s cubic-bezier(0.22,1,0.36,1), transform 0.6s cubic-bezier(0.22,1,0.36,1);
  }
  .tw-cursor {
    display: inline-block;
    color: var(--amber-500);
    animation: tw-blink 0.7s steps(1) infinite;
    font-weight: 300;
  }
  @keyframes tw-blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .imagine-intro {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    margin-bottom: 32px;
    transition: color 0.8s ease;
  }
  .imagine-intro.is-gone { color: rgba(255,255,255,0.2); pointer-events: none; }
  .imagine-lines {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .imagine-line {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: rgba(255,255,255,0.85);
  }
  .imagine-hl { color: var(--amber-500); }
  .imagine-sub {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.7;
    color: rgba(255,255,255,0.5);
    margin-top: 40px;
  }

  /* ── Features ────────────────────────────────────────────────────────── */
  .features-section {
    padding: 80px 0;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(3, 1fr); } }
  .feat-card {
    background: var(--surface-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .feat-card:hover {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-sm);
  }
  .feat-card:first-child { border-top: 3px solid var(--amber-500); }
  .feat-card:nth-child(2) { border-top: 3px solid var(--teal-500); }
  .feat-card:last-child { border-top: 3px solid var(--indigo-500); }
  .feat-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--color-primary-soft);
    color: var(--amber-600);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  [data-theme="dark"] .feat-icon { color: var(--amber-400); }
  .feat-card:nth-child(2) .feat-icon { background: var(--color-accent-soft); color: var(--teal-600); }
  [data-theme="dark"] .feat-card:nth-child(2) .feat-icon { color: var(--teal-400); }
  .feat-card:last-child .feat-icon { background: var(--color-secondary-soft); color: var(--indigo-600); }
  [data-theme="dark"] .feat-card:last-child .feat-icon { color: var(--indigo-400); }
  .feat-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .feat-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── Workflow ─────────────────────────────────────────────────────────── */
  .workflow-section {
    padding: 96px 0;
    background: var(--surface-subtle);
    border-bottom: 1px solid var(--border);
  }
  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .section-header h2 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    margin-bottom: 12px;
  }
  .section-sub {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .timeline {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .timeline-step {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 4px;
  }
  .step-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: var(--surface);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    position: relative;
  }
  .step-amber .step-icon { border-color: var(--amber-400); background: var(--color-primary-soft); color: var(--amber-600); }
  .step-teal .step-icon  { border-color: var(--teal-400);  background: var(--color-accent-soft);  color: var(--teal-600); }
  .step-indigo .step-icon { border-color: var(--indigo-400); background: var(--color-secondary-soft); color: var(--indigo-600); }
  :global([data-theme="dark"]) .step-amber .step-icon { color: var(--amber-400); }
  :global([data-theme="dark"]) .step-teal .step-icon  { color: var(--teal-400); }
  :global([data-theme="dark"]) .step-indigo .step-icon { color: var(--indigo-400); }
  .step-line {
    width: 2px;
    flex: 1;
    min-height: 48px;
    background: var(--border);
    margin: 4px 0;
  }
  .step-body {
    padding-bottom: 48px;
    flex: 1;
  }
  .timeline-step:last-child .step-body { padding-bottom: 0; }
  .step-time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .step-body h3 {
    font-size: 1.15rem;
    margin-bottom: 8px;
  }
  .step-body p {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 14px;
  }
  .step-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: var(--radius-full);
  }
  .tag-amber { background: var(--color-primary-soft); color: var(--amber-700); }
  .tag-teal  { background: var(--color-accent-soft);  color: var(--teal-700); }
  .tag-indigo { background: var(--color-secondary-soft); color: var(--indigo-600); }
  :global([data-theme="dark"]) .tag-amber { color: var(--amber-200); }
  :global([data-theme="dark"]) .tag-teal  { color: var(--teal-200); }
  :global([data-theme="dark"]) .tag-indigo { color: var(--indigo-200); }

  /* ── Coming soon ─────────────────────────────────────────────────────── */
  .coming-soon-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }
  .coming-card {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    background: var(--surface-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 56px 40px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .coming-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gradient-soft);
    opacity: 0.5;
    pointer-events: none;
  }
  .coming-card > * { position: relative; z-index: 1; }
  .coming-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--indigo-600);
    background: var(--color-secondary-soft);
    border: 1px solid var(--indigo-200);
    padding: 5px 14px;
    border-radius: var(--radius-full);
    display: inline-block;
  }
  :global([data-theme="dark"]) .coming-badge {
    color: #FFFFFF !important;
    border-color: rgba(255, 255, 255, 0.5);
    background: transparent;
  }
  .coming-card h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
  }
  .coming-title { color: var(--amber-500); }
  .coming-card p {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 420px;
    line-height: 1.7;
  }
  .btn-outline-lg {
    display: inline-block;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-primary);
    color: var(--color-primary-text);
    transition: background 0.2s, transform 0.15s;
    margin-top: 4px;
  }
  .btn-outline-lg:hover {
    background: var(--color-primary-soft);
    transform: translateY(-1px);
  }
  [data-theme="dark"] .btn-outline-lg { color: var(--amber-400); }

  /* ── Team ────────────────────────────────────────────────────────────── */
  .team-section {
    padding: 96px 0;
    border-bottom: 1px solid var(--border);
  }
  .team-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .team-left { display: flex; flex-direction: column; align-items: center; gap: 20px; max-width: 600px; }
  .team-left h2 { font-size: clamp(1.6rem, 3.5vw, 2.25rem); }
  .team-left p { color: var(--text-secondary); font-size: 1rem; line-height: 1.7; }
  .credential-row {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 24px;
    margin-top: 60px;
    width: 100%;
    max-width: 560px;
    align-self: center;
    margin-left: auto;
    margin-right: auto;
  }
  :global(.credential-logo svg) {
    width: auto !important;
    height: 90px !important;
    display: block;
    opacity: 0.85;
  }
  @media (max-width: 639px) {
    :global(.credential-logo svg) { height: 60px !important; }
  }
  .team-right {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .stat-card {
    background: var(--surface-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-top: 3px solid var(--amber-500);
  }
  .stat-card-secondary { border-top-color: var(--indigo-500); }
  .stat-card-accent { border-top-color: var(--teal-500); }
  .stat-number {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    line-height: 1;
  }
  .stat-plus { color: var(--amber-500); }
  .stat-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ── Bottom CTA ──────────────────────────────────────────────────────── */
  .cta-section {
    padding: 100px 0;
    background: var(--hero-bg);
    position: relative;
    overflow: hidden;
  }
  .cta-section::before { display: none; }
  .cta-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .cta-inner h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--hero-heading);
  }
  .cta-inner p { color: var(--hero-body); font-size: 1rem; }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 28px 0;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-copy {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  /* needed for footer brand text */
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
    color: var(--neutral-900);
  }
  :global([data-theme="dark"]) .brand-name { color: #FFFFFF; }
  .brand-ai { color: var(--amber-500); }


  /* ── Integrations carousel ───────────────────────────────────────────── */
  .integrations-section {
    padding: 120px 0;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
  }
  .carousel-track {
    overflow: hidden;
    margin-top: 56px;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }
  .carousel-inner {
    display: flex;
    align-items: center;
    width: max-content;
    animation: carousel-scroll 32s linear infinite;
  }
  @keyframes carousel-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .carousel-logo {
    width: 160px;
    height: 160px;
    object-fit: contain;
    border-radius: 18px;
    flex-shrink: 0;
    opacity: 0.85;
    margin-right: 300px;
  }

  /* ── Mobile (≤ 639px) ────────────────────────────────────────────────── */
  @media (max-width: 639px) {
    /* Nav: hide CTA button, keep toggle */
    .btn-cta { display: none; }
    .theme-picker { display: none; }
    .brand-mark { height: 22px; }
    .hero-logo { height: 52px; }

    /* Section padding */
    .hero { min-height: 100svh; }
    .features-section { padding: 52px 0; }
    .workflow-section { padding: 60px 0; }
    .integrations-section { padding: 52px 0; }
    .coming-soon-section { padding: 52px 0; }
    .team-section { padding: 60px 0; }
    .cta-section { padding: 64px 0; }

    /* Hero eyebrow: smaller to avoid overflow */
    .hero-eyebrow { font-size: 0.78rem; padding: 8px 14px; letter-spacing: 0.08em; }

    /* Coming card: reduce side padding */
    .coming-card { padding: 36px 20px; }

    /* Footer: stack vertically */
    .footer-inner { flex-direction: column; align-items: flex-start; }

    /* Section header: tighter */
    .section-header { margin-bottom: 40px; }

    /* Workflow timeline: tighten step spacing */
    .step-body { padding-bottom: 36px; }

  }

  /* ── Dark mode section differentiation ─────────────────────────────── */
  :global([data-theme="dark"]) .workflow-section,
  :global([data-theme="dark"]) .team-section {
    background: #1C1C2B;
  }
  :global([data-theme="dark"]) .integrations-section,
  :global([data-theme="dark"]) .coming-soon-section {
    background: #181825;
  }
  /* Subtle gradient divider on top of each section */
  :global([data-theme="dark"]) .workflow-section::before,
  :global([data-theme="dark"]) .integrations-section::before,
  :global([data-theme="dark"]) .coming-soon-section::before,
  :global([data-theme="dark"]) .team-section::before {
    content: '';
    display: block;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,140,66,0.2), rgba(91,83,232,0.2), rgba(23,190,187,0.2), transparent);
  }

  /* ── Scroll reveal ───────────────────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px) scale(0.98);
    transition: opacity 0.65s cubic-bezier(0.22,1,0.36,1), transform 0.65s cubic-bezier(0.22,1,0.36,1);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  [data-reveal][data-reveal-delay="1"] { transition-delay: 0.1s; }
  [data-reveal][data-reveal-delay="2"] { transition-delay: 0.2s; }
  [data-reveal][data-reveal-delay="3"] { transition-delay: 0.3s; }
  [data-reveal][data-reveal-delay="4"] { transition-delay: 0.4s; }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

  // Typewriter for imagine section
  const introEl = document.getElementById('imagine-intro');
  const imagineLines = document.querySelectorAll('#imagine-lines .imagine-line-hidden');
  const plainText = 'You wake up tomorrow and...';
  const finalHTML = 'You wake up <span class="imagine-hl">tomorrow</span> and...';

  function revealLines() {
    imagineLines.forEach((line, i) => {
      setTimeout(() => {
        line.style.opacity = '1';
        line.style.transform = 'translateY(0) scale(1)';
      }, i * 550);
    });
  }

  function runTypewriter() {
    let i = 0;
    const cursor = '<span class="tw-cursor">|</span>';
    const interval = setInterval(() => {
      i++;
      introEl.innerHTML = plainText.slice(0, i) + cursor;
      if (i === plainText.length) {
        clearInterval(interval);
        introEl.innerHTML = finalHTML;
        setTimeout(() => {
          introEl.classList.add('is-gone');
          revealLines();
        }, 1500);
      }
    }, 75);
  }

  const imagineSection = document.getElementById('imagine');
  let twStarted = false;
  const twObserver = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && !twStarted) {
      twStarted = true;
      twObserver.disconnect();
      setTimeout(runTypewriter, 200);
    }
  }, { threshold: 0.3 });
  if (imagineSection) twObserver.observe(imagineSection);

  // Burger menu
  const burger = document.getElementById('burger');
  const navLinks = document.getElementById('nav-links');
  burger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = navLinks.classList.toggle('is-open');
    burger.classList.toggle('is-open', open);
    burger.setAttribute('aria-expanded', String(open));
  });
  // Close on link click or outside click
  navLinks?.addEventListener('click', (e) => {
    if (e.target.tagName === 'A') {
      navLinks.classList.remove('is-open');
      burger.classList.remove('is-open');
      burger.setAttribute('aria-expanded', 'false');
    }
  });
  document.addEventListener('click', (e) => {
    if (!burger?.contains(e.target) && !navLinks?.contains(e.target)) {
      navLinks?.classList.remove('is-open');
      burger?.classList.remove('is-open');
      burger?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<script define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
  async function submitEmail(email) {
    const res = await fetch(`${supabaseUrl}/rest/v1/waitlist`, {
      method: 'POST',
      headers: {
        'apikey': supabaseKey,
        'Authorization': `Bearer ${supabaseKey}`,
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal',
      },
      body: JSON.stringify({ email }),
    });
    return res.ok || res.status === 201;
  }

  const CHECK_SVG = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;

  function wireForm(formId, successId) {
    const form = document.getElementById(formId);
    const success = document.getElementById(successId);
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[type="email"]');
      const btn = form.querySelector('button');
      const email = input.value.trim();
      if (!email) return;
      btn.disabled = true;
      btn.textContent = '…';
      const ok = await submitEmail(email);
      if (ok) {
        input.style.transition = 'opacity 0.3s, width 0.35s, padding 0.35s, margin 0.35s';
        input.style.opacity = '0';
        input.style.width = '0';
        input.style.padding = '0';
        input.style.margin = '0';
        btn.innerHTML = CHECK_SVG;
        btn.classList.add('is-success');
        if (success) {
          setTimeout(() => { success.hidden = false; }, 400);
        }
      } else {
        btn.disabled = false;
        btn.textContent = 'Try again';
      }
    });
  }

  wireForm('form-hero', 'success-hero');
  wireForm('form-cta', 'success-cta');
</script>
