  sliders: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>`,
  eye: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
};

const justAskSteps = [
  {
    icon: ICON.search,
    title: "It Proposes",
    titleColor: "amber",
    eyebrow: "Proactive",
    tags: [],
    color: "amber",
  },
  {
    icon: ICON.zap,
    title: "It Executes",
    titleColor: "amber",
    eyebrow: "Autonomous",
    tags: [],
    color: "teal",
  },
  {
    icon: ICON.repeat,
    title: "It Automates",
    titleColor: "amber",
    eyebrow: "Hands-off",
    tags: [],
    color: "indigo",
  },
];

const controlSteps = [
  {
    icon: ICON.bell,
    title: "You Decide",
    titleColor: "purple",
    eyebrow: "Approval first",
    tags: [],
    color: "amber",
  },
  {
    icon: ICON.sliders,
    title: "You Set the Rules",
    titleColor: "purple",
    eyebrow: "Your guardrails",
    tags: [],
    color: "teal",
  },
  {
    icon: ICON.eye,
    title: "You have full oversight",
    titleColor: "purple",
    eyebrow: "Full transparency",
    tags: [],
    color: "indigo",
