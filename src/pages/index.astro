const whatsappSteps = [
  {
    time: "7:30 AM",
    icon: ICON.sun,
    title: "Morning Briefing",
    tags: [],
    color: "amber",
  },
  {
    time: "During the day",
    icon: ICON.message,
    title: "Post-meeting update",
    tags: [],
    color: "teal",
  },
  {
    time: "End of day",
    icon: ICON.check,
    title: "Zero admin backlog",
    tags: [],
    color: "indigo",
