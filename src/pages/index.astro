  .cst-tile { fill: #ffffff; stroke: rgba(20,20,30,0.08); stroke-width: 1; }
  .cst-core { fill: var(--surface); stroke: var(--amber-500); stroke-width: 2.5; }
  .cst-core-glow {
    fill: var(--amber-400);
    transform-box: fill-box;
    transform-origin: center;
    animation: cstPulse 3.2s ease-in-out infinite;
  }
  @keyframes cstPulse {
    0%, 100% { transform: scale(1); opacity: 0.10; }
    50% { transform: scale(1.18); opacity: 0.20; }
  }
  .cst-core-label {
    fill: var(--text-muted);
