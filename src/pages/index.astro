---
import Layout from "@/layouts/Layout.astro";

const whatsappSteps = [
  {
    time: "7:30 AM",
    icon: "☀️",
    title: "Morning Briefing",
    body: "Rep wakes up to a WhatsApp message: today's meetings, prep notes for each prospect, a draft follow-up email, and a direct CRM link.",
    tags: ["Today's agenda", "Prospect prep", "Draft email", "CRM link"],
    color: "amber",
  },
  {
    time: "During the day",
    icon: "💬",
    title: "Post-meeting update",
    body: "Rep texts Mateos after each meeting. Notes are logged, CRM is updated, next steps are scheduled. All from WhatsApp.",
    tags: ["Text to log", "CRM auto-update", "Next steps set"],
    color: "teal",
  },
  {
    time: "End of day",
    icon: "✅",
    title: "Zero admin backlog",
    body: "~4 hours saved per rep per week. Every deal has a next action. You never drop the ball.",
    tags: ["4h saved / week", "Every deal tracked", "No missed follow-ups"],
    color: "indigo",
  },
];

const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2v4l-4-4H9a2 2 0 0 1-2-2v-1"/><path d="M15 6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2v4l4-4h2a2 2 0 0 0 2-2V6z"/></svg>`,
    title: "Come Prepared to Every Meeting",
    body: "Every rep gets a personalized briefing before each call: prospect history, last interaction, pain points, and a suggested approach.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: "No Deal Falls Between the Chairs",
    body: "Reps update Mateos by texting after meetings. Context stays current automatically. No deal goes cold because someone forgot to follow up.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Built for WhatsApp-First Markets",
    body: "WhatsApp is the #1 sales channel in our beachhead market. Most generic AI tools don't serve it. We do, natively, from day one.",
  },
];

const integrations = [
  { name: "WhatsApp",        src: "/whatsapp.svg" },
  { name: "HubSpot",         src: "/hubspot.webp" },
  { name: "Notion",          src: "/notion.webp" },
  { name: "Zendesk",         src: "/zendesk.webp" },
  { name: "Salesforce",      src: "/salesforce.webp" },
  { name: "Monday",          src: "/monday.webp" },
  { name: "ClickUp",         src: "/clickup.webp" },
  { name: "Todoist",         src: "/todoist.webp" },
  { name: "Gmail",           src: "/gmail.webp" },
  { name: "Google Calendar", src: "/gcalendar.webp" },
  { name: "Outlook",         src: "/outlook.webp" },
];

const teamLogos = [
  {
    label: "Google",
    svg: `<svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
    </svg>`,
  },
  {
    label: "Slack",
    svg: `<svg width="20" height="20" viewBox="0 0 127 127" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M27.2 80c0 7.3-5.9 13.2-13.2 13.2C6.7 93.2.8 87.3.8 80c0-7.3 5.9-13.2 13.2-13.2h13.2V80z" fill="#E01E5A"/>
      <path d="M33.8 80c0-7.3 5.9-13.2 13.2-13.2 7.3 0 13.2 5.9 13.2 13.2v33c0 7.3-5.9 13.2-13.2 13.2-7.3 0-13.2-5.9-13.2-13.2V80z" fill="#E01E5A"/>
      <path d="M47 27c-7.3 0-13.2-5.9-13.2-13.2C33.8 6.5 39.7.6 47 .6c7.3 0 13.2 5.9 13.2 13.2V27H47z" fill="#36C5F0"/>
      <path d="M47 33.8c7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2H14c-7.3 0-13.2-5.9-13.2-13.2 0-7.3 5.9-13.2 13.2-13.2h33z" fill="#36C5F0"/>
      <path d="M100 47c0-7.3 5.9-13.2 13.2-13.2 7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2H100V47z" fill="#2EB67D"/>
      <path d="M93.4 47c0 7.3-5.9 13.2-13.2 13.2-7.3 0-13.2-5.9-13.2-13.2V14c0-7.3 5.9-13.2 13.2-13.2 7.3 0 13.2 5.9 13.2 13.2v33z" fill="#2EB67D"/>
      <path d="M80.2 100c7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2-7.3 0-13.2-5.9-13.2-13.2V100h13.2z" fill="#ECB22E"/>
      <path d="M80.2 93.4c-7.3 0-13.2-5.9-13.2-13.2 0-7.3 5.9-13.2 13.2-13.2H113c7.3 0 13.2 5.9 13.2 13.2 0 7.3-5.9 13.2-13.2 13.2H80.2z" fill="#ECB22E"/>
    </svg>`,
  },
  {
    label: "MIT",
    svg: `<svg width="36" height="20" viewBox="0 0 54 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <text x="0" y="20" font-family="Georgia,serif" font-weight="700" font-size="22" fill="#A31F34">MIT</text>
    </svg>`,
  },
  {
    label: "UMass Boston",
    svg: `<svg width="60" height="20" viewBox="0 0 120 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <text x="0" y="17" font-family="Georgia,serif" font-weight="700" font-size="14" fill="#881C1C">UMass</text>
      <text x="0" y="24" font-family="Georgia,serif" font-weight="400" font-size="9" letter-spacing="1" fill="#881C1C">BOSTON</text>
    </svg>`,
  },
];
---

<Layout>
  <!-- ── NAVBAR ──────────────────────────────────────────────────────── -->
  <header>
    <div class="wrap bar">
      <a href="/" class="brand" aria-label="Mateos.ai home">
        <img src="/mateos-logo.svg" alt="" class="brand-mark" />
        <span class="brand-name">mateos<span class="brand-ai">.ai</span></span>
      </a>

      <div class="nav-right">
        <nav class="nav-links">
          <a href="#workflow">Workflow</a>
          <a href="#integrations">Integrations</a>
          <a href="#agents">Agents</a>
          <a href="#team">Team</a>
        </nav>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <!-- Sun -->
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <!-- Moon -->
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <a href="mailto:david@mateos.ai" class="btn-cta">Request access</a>
      </div>
    </div>
  </header>

  <main>
    <!-- ── HERO ───────────────────────────────────────────────────────── -->
    <section class="hero" id="product">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="wrap hero-inner">
        <img src="/mateos-logo-secondary.svg" alt="" class="hero-logo" />
        <h1>Mateos'<br /><span class="gradient-text">Sales Magician</span></h1>
        <p class="hero-tagline">You Never Miss a Cold Lead Again</p>
        <p class="hero-sub">
          Every morning, your rep gets a WhatsApp briefing: here's your day,
          here's prep for each meeting, here's a draft email, here's the CRM link.
        </p>
        <div class="hero-pills">
          <span class="pill">WhatsApp native</span>
          <span class="pill">CRM integrated</span>
          <span class="pill">Zero admin</span>
        </div>
        <div class="hero-actions">
          <a href="mailto:david@mateos.ai" class="btn-primary-lg">Get early access</a>
          <a href="#workflow" class="btn-ghost-lg">See how it works ↓</a>
        </div>
      </div>
    </section>

    <!-- ── FEATURES ───────────────────────────────────────────────────── -->
    <section class="features-section">
      <div class="wrap">
        <div class="features-grid">
          {features.map((f) => (
            <div class="feat-card">
              <div class="feat-icon" set:html={f.icon} />
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── WORKFLOW ────────────────────────────────────────────────────── -->
    <section class="workflow-section" id="workflow">
      <div class="wrap">
        <div class="section-header">
          <div class="eyebrow">A day in the life</div>
          <h2>Concrete workflow.<br />Real time savings.</h2>
          <p class="section-sub">
            See exactly how a rep's day looks when Mateos handles the admin.
          </p>
        </div>
        <div class="timeline">
          {whatsappSteps.map((step, i) => (
            <div class={`timeline-step step-${step.color}`}>
              <div class="step-marker">
                <span class="step-icon">{step.icon}</span>
                {i < whatsappSteps.length - 1 && <div class="step-line" />}
              </div>
              <div class="step-body">
                <div class="step-time">{step.time}</div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
                <div class="step-tags">
                  {step.tags.map((tag) => (
                    <span class={`tag tag-${step.color}`}>{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── INTEGRATIONS ──────────────────────────────────────────────── -->
    <section class="integrations-section" id="integrations">
      <div class="wrap">
        <div class="section-header">
          <div class="eyebrow">Integrations</div>
          <h2>Works with your stack</h2>
          <p class="section-sub">Mateos connects to the tools your team already uses.</p>
        </div>
        <div class="integrations-grid">
          {integrations.map((i) => (
            <div class="integration-tile">
              <img src={i.src} alt={i.name} class="integration-logo" />
              <span class="integration-name">{i.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── 24/7 AI OFFICER ────────────────────────────────────────────── -->
    <section class="coming-soon-section" id="agents">
      <div class="wrap">
        <div class="coming-card">
          <div class="coming-badge">Coming soon</div>
          <h2>24/7 AI Officer</h2>
          <p>
            An always-on AI executive embedded in your business: monitoring
            pipelines, flagging risks, and acting before you need to ask.
          </p>
          <a href="mailto:david@mateos.ai" class="btn-outline-lg">
            Join the waitlist
          </a>
        </div>
      </div>
    </section>

    <!-- ── TEAM ───────────────────────────────────────────────────────── -->
    <section class="team-section" id="team">
      <div class="wrap">
        <div class="team-grid">
          <div class="team-left">
            <div class="eyebrow">The team</div>
            <h2>Built by people who've done it before</h2>
            <p>
              Our team comes from Google, Slack, MIT, and UMass Boston, with
              deep roots in AI research and enterprise software.
            </p>
            <div class="credential-badges">
              {teamLogos.map((c) => (
                <span class="credential">
                  <span set:html={c.svg} />
                  {c.label}
                </span>
              ))}
            </div>
          </div>
          <div class="team-right">
            <div class="stat-card">
              <div class="stat-number">3<span class="stat-plus">+</span></div>
              <div class="stat-label">years building AI solutions<br/>for SMBs</div>
            </div>
            <div class="stat-card stat-card-secondary">
              <div class="stat-number">∞</div>
              <div class="stat-label">domains served.<br/>We know your industry.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────────────── -->
    <section class="cta-section">
      <div class="wrap cta-inner">
        <h2>Ready to automate your sales ops?</h2>
        <p>Join the early access list. We'll reach out to set you up.</p>
        <a href="mailto:david@mateos.ai" class="btn-primary-lg">Get early access →</a>
      </div>
    </section>
  </main>

  <!-- ── FOOTER ─────────────────────────────────────────────────────── -->
  <footer>
    <div class="wrap footer-inner">
      <div class="brand" aria-label="Mateos.ai">
        <svg width="22" height="22" viewBox="43 43 114 114" aria-hidden="true">
          <circle cx="130" cy="70" r="27" fill="#FF8C42"/>
          <circle cx="70" cy="130" r="27" fill="#17BEBB"/>
          <circle cx="130" cy="130" r="27" fill="#5B53E8"/>
        </svg>
        <span class="brand-name">mateos<span class="brand-ai">.ai</span></span>
      </div>
      <span class="footer-copy">© 2026 Mateos AI · All rights reserved.</span>
    </div>
  </footer>
</Layout>

<style>
  /* ── Navbar ──────────────────────────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--nav-bg);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--nav-border);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .brand-mark {
    height: 28px;
    width: auto;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .nav-links {
    display: none;
    gap: 24px;
  }
  @media (min-width: 640px) { .nav-links { display: flex; } }
  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text-primary); }
  .btn-cta {
    display: inline-block;
    background: var(--color-primary);
    color: var(--on-primary);
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .btn-cta:hover { background: var(--color-primary-hover); transform: translateY(-1px); }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--hero-bg);
    padding: 100px 0 90px;
    text-align: center;
  }
  .hero-glow { display: none; }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .hero-logo {
    height: 72px;
    width: auto;
    margin-bottom: 8px;
  }
  .hero h1 {
    font-size: clamp(3rem, 8vw, 5.5rem);
    color: var(--hero-heading);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 600;
    color: var(--hero-body);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .gradient-text {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    max-width: 520px;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--hero-body);
  }
  .hero-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .pill {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--hero-pill-text);
    border: 1px solid var(--hero-pill-border);
    background: var(--hero-pill-bg);
    padding: 5px 12px;
    border-radius: var(--radius-full);
  }
  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }
  .btn-primary-lg {
    display: inline-block;
    background: var(--color-primary);
    color: var(--on-primary);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.75rem 1.6rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: var(--shadow-md);
  }
  .btn-primary-lg:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  .btn-ghost-lg {
    display: inline-block;
    font-size: 0.95rem;
    color: var(--hero-ghost-text);
    padding: 0.75rem 1.2rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--hero-ghost-border);
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost-lg:hover { color: var(--hero-heading); border-color: var(--border-strong); }

  /* ── Features ────────────────────────────────────────────────────────── */
  .features-section {
    padding: 80px 0;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(3, 1fr); } }
  .feat-card {
    background: var(--surface-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .feat-card:hover {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-sm);
  }
  .feat-card:first-child { border-top: 3px solid var(--amber-500); }
  .feat-card:nth-child(2) { border-top: 3px solid var(--teal-500); }
  .feat-card:last-child { border-top: 3px solid var(--indigo-500); }
  .feat-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--color-primary-soft);
    color: var(--amber-600);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  [data-theme="dark"] .feat-icon { color: var(--amber-400); }
  .feat-card:nth-child(2) .feat-icon { background: var(--color-accent-soft); color: var(--teal-600); }
  [data-theme="dark"] .feat-card:nth-child(2) .feat-icon { color: var(--teal-400); }
  .feat-card:last-child .feat-icon { background: var(--color-secondary-soft); color: var(--indigo-600); }
  [data-theme="dark"] .feat-card:last-child .feat-icon { color: var(--indigo-400); }
  .feat-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .feat-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── Workflow ─────────────────────────────────────────────────────────── */
  .workflow-section {
    padding: 96px 0;
    background: var(--surface-subtle);
    border-bottom: 1px solid var(--border);
  }
  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 12px;
  }
  .section-sub {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .timeline {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .timeline-step {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 4px;
  }
  .step-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: var(--surface);
