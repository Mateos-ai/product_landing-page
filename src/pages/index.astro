  @keyframes cstLive { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

  @media (prefers-reduced-motion: reduce) {
    .cst-line-flow, .cst-core-glow, .cst-agent-live { animation: none; }
    .cst-line-flow { stroke-dasharray: none; opacity: 0.55; }
