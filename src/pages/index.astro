    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .timeline {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .timeline-step {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }
  .step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 4px;
  }
  .step-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: var(--surface);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    position: relative;
  }
  .step-amber .step-icon { border-color: var(--amber-400); background: var(--color-primary-soft); color: var(--amber-600); }
  .step-teal .step-icon  { border-color: var(--teal-400);  background: var(--color-accent-soft);  color: var(--teal-600); }
  .step-indigo .step-icon { border-color: var(--indigo-400); background: var(--color-secondary-soft); color: var(--indigo-600); }
  :global([data-theme="dark"]) .step-amber .step-icon { color: var(--amber-400); }
  :global([data-theme="dark"]) .step-teal .step-icon  { color: var(--teal-400); }
  :global([data-theme="dark"]) .step-indigo .step-icon { color: var(--indigo-400); }
  .step-line {
    width: 2px;
    flex: 1;
    min-height: 48px;
    background: var(--border);
    margin: 4px 0;
  }
  .step-body {
    padding-bottom: 48px;
    flex: 1;
  }
  .timeline-step:last-child .step-body { padding-bottom: 0; }
  .step-time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .step-body h3 {
    font-size: 1.15rem;
    margin-bottom: 8px;
  }
  .step-body p {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 14px;
  }
  .step-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
  }
  .tag-amber { background: var(--color-primary-soft); color: var(--amber-700); }
  .tag-teal  { background: var(--color-accent-soft);  color: var(--teal-700); }
  .tag-indigo { background: var(--color-secondary-soft); color: var(--indigo-600); }
  :global([data-theme="dark"]) .tag-amber { color: var(--amber-200); }
  :global([data-theme="dark"]) .tag-teal  { color: var(--teal-200); }
  :global([data-theme="dark"]) .tag-indigo { color: var(--indigo-200); }

  /* ── Two-column split: text + browser mockup (big screens only) ───────── */
  .split-visual { display: none; }

  @media (min-width: 1024px) {
    .section-split {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 56px;
      align-items: center;
    }
    .section-split > .section-header { grid-column: 1 / -1; margin-bottom: 0; }
    .split-text { min-width: 0; }
    .split-text .timeline { margin: 0; max-width: none; }
    .split-visual { display: block; }
  }

  /* ── Browser mockup content ───────────────────────────────────────────── */
  .bm-chat { display: flex; flex-direction: column; gap: 12px; }
  .bm-msg { display: flex; gap: 10px; align-items: flex-start; }
  .bm-avatar {
    width: 28px; height: 28px; flex-shrink: 0;
    border-radius: var(--radius-full);
    background: var(--color-primary); color: var(--on-primary);
    font-family: var(--font-display); font-weight: 700; font-size: 0.8rem;
    display: flex; align-items: center; justify-content: center;
  }
  .bm-avatar-teal { background: var(--color-accent); }
  .bm-avatar-indigo { background: var(--color-secondary); color: #fff; }
  .bm-bubble {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 4px 14px 14px 14px;
    padding: 9px 13px;
    font-size: 0.82rem; line-height: 1.5; color: var(--text-primary);
    box-shadow: var(--shadow-xs);
    display: flex; align-items: center; flex-wrap: wrap; gap: 6px;
  }
  .bm-bubble-teal {
    border-color: var(--teal-300); background: var(--color-accent-soft); color: var(--teal-700);
  }
  :global([data-theme="dark"]) .bm-bubble-teal { color: var(--teal-200); }

  .bm-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 14px; box-shadow: var(--shadow-sm);
    display: flex; flex-direction: column; gap: 10px;
  }
  .bm-card-approve { border-color: var(--indigo-300); }
  .bm-card-head {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.04em;
    text-transform: uppercase; color: var(--text-muted);
  }
  .bm-card-body { font-size: 0.82rem; line-height: 1.5; color: var(--text-primary); }
  .bm-line {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.8rem; color: var(--text-primary);
  }
  .bm-time {
    font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted);
    width: 38px; flex-shrink: 0;
  }
  .bm-line-title { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .bm-chip {
    font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600;
    padding: 3px 8px; border-radius: var(--radius-full); white-space: nowrap;
    text-transform: uppercase; letter-spacing: 0.04em; flex-shrink: 0;
  }
  .bm-chip-amber { background: var(--color-primary-soft); color: var(--amber-700); }
  .bm-chip-teal  { background: var(--color-accent-soft);  color: var(--teal-700); }
  .bm-chip-indigo { background: var(--color-secondary-soft); color: var(--indigo-600); }
  .bm-chip-purple { background: var(--color-secondary-soft); color: var(--color-secondary); }
  :global([data-theme="dark"]) .bm-chip-amber { color: var(--amber-200); }
  :global([data-theme="dark"]) .bm-chip-teal  { color: var(--teal-200); }
  :global([data-theme="dark"]) .bm-chip-indigo,
  :global([data-theme="dark"]) .bm-chip-purple { color: var(--indigo-200); }

  .bm-actions { display: flex; gap: 8px; }
  .bm-btn {
    font-size: 0.76rem; font-weight: 600; padding: 6px 14px;
    border-radius: var(--radius-sm); border: 1px solid var(--border);
    color: var(--text-secondary); background: var(--surface);
  }
  .bm-btn-primary {
    background: var(--color-primary); border-color: var(--color-primary); color: var(--on-primary);
  }

  .bm-panel { display: flex; flex-direction: column; gap: 10px; }
  .bm-panel-label {
    font-family: var(--font-mono); font-size: 0.66rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-muted); margin-top: 6px;
  }
  .bm-rule {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 10px 12px;
  }
  .bm-rule-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .bm-rule-title { font-size: 0.82rem; font-weight: 600; color: var(--text-primary); }
  .bm-rule-sub { font-size: 0.72rem; color: var(--text-muted); }
  .bm-switch {
    width: 34px; height: 20px; border-radius: var(--radius-full);
    background: var(--neutral-300); position: relative; flex-shrink: 0;
  }
  .bm-switch.on { background: var(--color-accent); }
  .bm-switch::after {
    content: ''; position: absolute; top: 2px; left: 2px;
    width: 16px; height: 16px; border-radius: var(--radius-full);
    background: #fff; box-shadow: var(--shadow-xs);
  }
  .bm-switch.on::after { left: 16px; }
  .bm-panel-foot {
    font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);
    text-align: center; margin-top: 4px;
  }

  /* ── Pinned, scroll-driven workflow section ──────────────────────────── */
  .pin-track { position: relative; }
  .pin-header { text-align: center; margin-bottom: 36px; position: relative; z-index: 2; }
  .pin-header h2 { font-size: clamp(2rem, 4.5vw, 3.25rem); }
  .pin-dots { display: none; justify-content: center; gap: 8px; margin-top: 18px; }
  .pin-dot {
    width: 8px; height: 8px; border-radius: var(--radius-full);
    background: var(--border-strong); transition: width 0.3s, background 0.3s;
  }
  .pin-dot.is-active { width: 22px; background: var(--color-primary); }

  .pin-deck { position: relative; z-index: 1; }
  /* panel inner layout — applies in both stacked (fallback) and pinned modes */
  .pin-panel {
    display: flex; flex-direction: column; gap: 24px; align-items: center;
    margin-bottom: 48px;
  }
  .pin-panel:last-child { margin-bottom: 0; }
  .pin-meta { display: flex; gap: 20px; align-items: flex-start; width: 100%; max-width: 460px; }
  .pin-meta .step-icon { flex-shrink: 0; }
  .pin-meta-text h3 { font-size: 1.5rem; margin: 4px 0 12px; }
  .pin-visual { width: 100%; max-width: 460px; }

  .pin-window {
    border-radius: var(--radius-lg); background: var(--surface);
    border: 1px solid var(--border); box-shadow: var(--shadow-xl); overflow: hidden;
  }
  .pin-window-chrome {
    display: flex; align-items: center; gap: 8px;
    padding: 11px 14px; background: var(--surface-muted); border-bottom: 1px solid var(--border);
  }
  .pin-window-chrome .dot { width: 11px; height: 11px; border-radius: var(--radius-full); flex-shrink: 0; }
  .pin-window-chrome .dot-red { background: #FF5F57; }
  .pin-window-chrome .dot-amber { background: #FEBC2E; }
  .pin-window-chrome .dot-green { background: #28C840; }
  .pin-window-url {
    flex: 1; text-align: center; font-family: var(--font-mono);
    font-size: 0.72rem; color: var(--text-muted);
  }
  .pin-window-body { padding: 18px; background: var(--surface-subtle); }
  :global([data-theme="dark"]) .pin-window-body { background: var(--neutral-900); }

  @media (min-width: 1024px) {
    .pin-panel {
      display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 48px; align-items: center;
    }
    .pin-meta { justify-self: end; max-width: 420px; }
    .pin-visual { justify-self: start; }
  }

  /* ── Pinned mode (JS opt-in) ─────────────────────────────────────────── */
  #workflow.pin-active { padding: 0; }
  #workflow.pin-active .pin-track {
    height: calc((var(--pin-steps) + 1) * 100vh);
    height: calc((var(--pin-steps) + 1) * 100svh);
  }
  #workflow.pin-active .pin-stage {
    position: sticky; top: 0;
    height: 100vh;
    height: 100svh;
  }
  #workflow.pin-active .pin-stage-inner {
    height: 100%; display: flex; flex-direction: column; justify-content: center;
    padding-top: 76px; padding-bottom: 32px;
  }
  #workflow.pin-active .pin-dots { display: flex; }
  #workflow.pin-active .pin-deck { flex: 1 1 auto; min-height: 0; }
  #workflow.pin-active .pin-panel {
    position: absolute; inset: 0; margin: 0;
    opacity: 0; transform: translateY(40px); pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.22,1,0.36,1), transform 0.5s cubic-bezier(0.22,1,0.36,1);
  }
  #workflow.pin-active .pin-panel.is-active { opacity: 1; transform: translateY(0); pointer-events: auto; }
  #workflow.pin-active .pin-panel.is-above { opacity: 0; transform: translateY(-48px); }
  #workflow.pin-active .pin-panel.is-below { opacity: 0; transform: translateY(40px); }

  /* ── Demo-card interaction helpers (new classes only) ────────────────── */
  .bm-chip-empty { background: var(--surface-muted); color: var(--text-muted); }
  .bm-chip.is-filling { animation: bmPop 0.3s ease; }
  @keyframes bmPop { 0% { transform: scale(0.85); } 60% { transform: scale(1.08); } 100% { transform: scale(1); } }
  .bm-result.is-in { animation: bmSlideIn 0.4s ease; }
  @keyframes bmSlideIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .bm-todo { gap: 10px; }
  .bm-check {
    width: 18px; height: 18px; flex-shrink: 0; border-radius: var(--radius-full);
    border: 2px solid var(--border-strong); display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.25s, border-color 0.25s;
  }
  .bm-check::after { content: '✓'; font-size: 0.66rem; line-height: 1; color: #fff; opacity: 0; transition: opacity 0.2s; }
  .bm-check.is-done { background: var(--color-accent); border-color: var(--color-accent); }
  .bm-check.is-done::after { opacity: 1; }
  .bm-btn.is-busy { opacity: 0.75; cursor: default; }

  /* Morning-briefing: agenda + prep-detail flow */
  .bm-briefing [hidden] { display: none; }
  .bm-btn-sm { padding: 4px 12px; font-size: 0.72rem; flex-shrink: 0; }
  .bm-meeting { display: flex; align-items: center; gap: 10px; border-top: 1px solid var(--border); padding: 11px 0; }
  .bm-meeting:first-of-type { border-top: 0; }
  .bm-meeting .bm-line-title { flex: 1; }

  /* status bar */
  .bm-statusbar { padding: 4px 0 10px; animation: bmSlideIn 0.3s ease; }
  .bm-statusbar-track { height: 6px; border-radius: var(--radius-full); background: var(--surface-muted); overflow: hidden; }
  .bm-statusbar-fill { height: 100%; width: 0; border-radius: var(--radius-full); background: var(--color-primary); }
  .bm-statusbar-text { margin-top: 8px; font-size: 0.74rem; color: var(--text-secondary); font-family: var(--font-mono); }

  /* prep detail (card takeover) */
  .bm-back {
    background: none; border: 0; padding: 0; margin-bottom: 14px; cursor: pointer;
    font-family: var(--font-body); font-size: 0.78rem; color: var(--text-muted);
  }
  .bm-back:hover { color: var(--text-primary); }
  .bm-detail-title { display: flex; align-items: center; gap: 9px; margin-bottom: 16px; font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; }
  .bm-detail-title .bm-time { font-size: 0.95rem; color: var(--text-muted); }
  .bm-detail-sep { color: var(--border-strong); font-weight: 400; }
  .bm-prep-brief { display: flex; flex-direction: column; gap: 9px; }
  .bm-prep-row { display: flex; gap: 12px; font-size: 0.82rem; line-height: 1.45; }
  .bm-prep-key {
    flex-shrink: 0; width: 80px; font-family: var(--font-mono); font-size: 0.66rem;
    text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); padding-top: 2px;
  }
  .bm-prep-brief + .bm-actions { margin-top: 16px; }
  .bm-btn-spin {
    display: inline-block; width: 12px; height: 12px; margin-right: 7px; vertical-align: -1px;
    border-radius: var(--radius-full);
    border: 2px solid rgba(0,0,0,0.2); border-top-color: currentColor;
    animation: bmSpin 0.6s linear infinite;
  }
  @keyframes bmSpin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .bm-btn-spin { animation: none; } }

  @media (prefers-reduced-motion: reduce) {
    #workflow.pin-active { padding: 96px 0; }
    #workflow.pin-active .pin-track { height: auto !important; }
    #workflow.pin-active .pin-stage { position: static; height: auto; }
    #workflow.pin-active .pin-stage-inner { display: block; padding-top: 0; }
    #workflow.pin-active .pin-dots { display: none; }
    #workflow.pin-active .pin-panel {
      position: static; inset: auto; opacity: 1; transform: none;
      pointer-events: auto; margin-bottom: 48px;
    }
  }

  /* ── Coming soon ─────────────────────────────────────────────────────── */
  .coming-soon-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }
  .coming-card {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    background: var(--surface-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 56px 40px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .coming-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gradient-soft);
    opacity: 0.5;
    pointer-events: none;
  }
  .coming-card > * { position: relative; z-index: 1; }
  .coming-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--indigo-600);
    background: var(--color-secondary-soft);
    border: 1px solid var(--indigo-200);
    padding: 5px 14px;
    border-radius: var(--radius-full);
    display: inline-block;
  }
  :global([data-theme="dark"]) .coming-badge {
    color: #FFFFFF !important;
    border-color: rgba(255, 255, 255, 0.5);
    background: transparent;
  }
  .coming-card h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
  }
  .coming-title { color: var(--amber-500); }
  .coming-card p {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 420px;
    line-height: 1.7;
  }
  .btn-outline-lg {
    display: inline-block;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-primary);
    color: var(--color-primary-text);
    transition: background 0.2s, transform 0.15s;
    margin-top: 4px;
  }
  .btn-outline-lg:hover {
    background: var(--color-primary-soft);
    transform: translateY(-1px);
  }
  [data-theme="dark"] .btn-outline-lg { color: var(--amber-400); }

  /* ── Team ────────────────────────────────────────────────────────────── */
  .team-section {
    padding: 96px 0;
    border-bottom: 1px solid var(--border);
  }
  .team-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .team-left { display: flex; flex-direction: column; align-items: center; gap: 20px; max-width: 600px; }
  .team-left h2 { font-size: clamp(1.6rem, 3.5vw, 2.25rem); }
  .team-left p { color: var(--text-secondary); font-size: 1rem; line-height: 1.7; }
  .credential-row {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 24px;
    margin-top: 60px;
    width: 100%;
    max-width: 560px;
    align-self: center;
    margin-left: auto;
    margin-right: auto;
  }
  :global(.credential-logo svg) {
    width: auto !important;
    height: 90px !important;
    display: block;
    opacity: 0.85;
  }
  @media (max-width: 639px) {
    :global(.credential-logo svg) { height: 60px !important; }
  }
  .team-right {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .stat-card {
    background: var(--surface-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-top: 3px solid var(--amber-500);
  }
  .stat-card-secondary { border-top-color: var(--indigo-500); }
  .stat-card-accent { border-top-color: var(--teal-500); }
  .stat-number {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    line-height: 1;
  }
  .stat-plus { color: var(--amber-500); }
  .stat-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ── Bottom CTA ──────────────────────────────────────────────────────── */
  .cta-section {
    padding: 100px 0;
    background: var(--hero-bg);
    position: relative;
    overflow: hidden;
  }
  .cta-section::before { display: none; }
  .cta-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .cta-inner h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--hero-heading);
  }
  .cta-inner p { color: var(--hero-body); font-size: 1rem; }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 28px 0;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-copy {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  /* needed for footer brand text */
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
    color: var(--neutral-900);
  }
  :global([data-theme="dark"]) .brand-name { color: #FFFFFF; }
  .brand-ai { color: var(--amber-500); }


  /* ── Integrations carousel ───────────────────────────────────────────── */
  .integrations-section {
    padding: 120px 0;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
  }
  .carousel-track {
    overflow: hidden;
    margin-top: 56px;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }
  .carousel-inner {
    display: flex;
    align-items: center;
    width: max-content;
    animation: carousel-scroll 32s linear infinite;
  }
  @keyframes carousel-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .carousel-logo {
    width: 160px;
    height: 160px;
    object-fit: contain;
    border-radius: 18px;
    flex-shrink: 0;
    opacity: 0.85;
    margin-right: 300px;
  }

  /* ── Mobile (≤ 639px) ────────────────────────────────────────────────── */
  @media (max-width: 639px) {
    /* Nav: hide CTA button, keep toggle */
    .btn-cta { display: none; }
    .theme-picker { display: none; }
    .brand-mark { height: 22px; }
    .hero-logo { height: 52px; }

    /* Section padding */
    .hero { min-height: 100svh; }
    .features-section { padding: 52px 0; }
    .workflow-section { padding: 60px 0; }
    .integrations-section { padding: 52px 0; }
    .coming-soon-section { padding: 52px 0; }
    .team-section { padding: 60px 0; }
    .cta-section { padding: 64px 0; }

    /* Hero eyebrow: smaller to avoid overflow */
    .hero-eyebrow { font-size: 0.78rem; padding: 8px 14px; letter-spacing: 0.08em; }

    /* Coming card: reduce side padding */
    .coming-card { padding: 36px 20px; }

    /* Footer: stack vertically */
    .footer-inner { flex-direction: column; align-items: flex-start; }

    /* Section header: tighter */
    .section-header { margin-bottom: 40px; }

    /* Workflow timeline: tighten step spacing */
    .step-body { padding-bottom: 36px; }

  }

  /* ── Dark mode section differentiation ─────────────────────────────── */
  :global([data-theme="dark"]) .workflow-section,
  :global([data-theme="dark"]) .team-section {
    background: #1C1C2B;
  }
  :global([data-theme="dark"]) .integrations-section,
  :global([data-theme="dark"]) .coming-soon-section {
    background: #181825;
  }
  /* Subtle gradient divider on top of each section */
  :global([data-theme="dark"]) .workflow-section::before,
  :global([data-theme="dark"]) .integrations-section::before,
  :global([data-theme="dark"]) .coming-soon-section::before,
  :global([data-theme="dark"]) .team-section::before {
    content: '';
    display: block;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,140,66,0.2), rgba(91,83,232,0.2), rgba(23,190,187,0.2), transparent);
  }

  /* ── Scroll reveal ───────────────────────────────────────────────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px) scale(0.98);
    transition: opacity 0.65s cubic-bezier(0.22,1,0.36,1), transform 0.65s cubic-bezier(0.22,1,0.36,1);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  [data-reveal][data-reveal-delay="1"] { transition-delay: 0.1s; }
  [data-reveal][data-reveal-delay="2"] { transition-delay: 0.2s; }
  [data-reveal][data-reveal-delay="3"] { transition-delay: 0.3s; }
  [data-reveal][data-reveal-delay="4"] { transition-delay: 0.4s; }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

  // ── Pinned workflow: scroll progress → active step ──────────────────────
  (function () {
    var track = document.querySelector('[data-pin-track]');
    var stage = document.querySelector('[data-pin-stage]');
    if (!track || !stage) return;

    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return; // leave the stacked CSS fallback in place

    var section = document.getElementById('workflow');
    section.classList.add('pin-active');

    var panels = stage.querySelectorAll('[data-panel]');
    var dots = stage.querySelectorAll('[data-dot]');
    var N = panels.length;
    var current = -1;
    var ticking = false;

    function clamp(v, a, b) { return v < a ? a : (v > b ? b : v); }

    function setStep(i) {
      if (i === current) return;
      current = i;
      stage.setAttribute('data-step', i);
      for (var k = 0; k < panels.length; k++) {
        var active = (k === i);
        panels[k].classList.toggle('is-active', active);
        panels[k].classList.toggle('is-above', k < i);
        panels[k].classList.toggle('is-below', k > i);
        panels[k].setAttribute('aria-hidden', active ? 'false' : 'true');
      }
      for (var d = 0; d < dots.length; d++) {
        dots[d].classList.toggle('is-active', d === i);
      }
    }

    function update() {
      ticking = false;
      var total = track.offsetHeight - stage.offsetHeight;
      if (total <= 0) { setStep(0); return; }
      var p = clamp(-track.getBoundingClientRect().top / total, 0, 1);
      var step = Math.floor(p * N);
      if (step > N - 1) step = N - 1;
      setStep(step);
    }

    function onScroll() {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    setStep(0);
    update();
  })();

  // ── Pinned workflow: interactive demo-card actions (local only) ─────────
  (function () {
    var root = document.getElementById('workflow');
    if (!root) return;

    var PREP_STEPS = [
      'Reading the event description',
      'Analyzing the participants',
      'Reading company info in CRM',
      'Gathering everything',
      'Writing summary'
    ];
    var PREP_LINE_MS = 700;

    root.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-action]');
      if (!btn || btn.classList.contains('is-busy')) return;
      var action = btn.getAttribute('data-action');
      if (action === 'prep') runPrep(btn);
      else if (action === 'prep-back') closeDetail(btn);
      else if (action === 'prep-email') emailPrep(btn);
      else if (action === 'sync') runSync(btn);
      else if (action === 'clear') runClear(btn);
    });

    function runPrep(btn) {
      var card = btn.closest('[data-briefing]');
      if (!card) return;
      var state = card.getAttribute('data-prep-state');

      // already prepped → straight to the detail view (no loading)
      if (state === 'ready') { openDetail(card); return; }

      // idle → run the status-bar loading, then surface "Read Prep"
      card.setAttribute('data-prep-state', 'loading');
      btn.classList.add('is-busy');
      btn.style.visibility = 'hidden';

      var bar = card.querySelector('[data-statusbar]');
      var fill = card.querySelector('[data-statusfill]');
      var text = card.querySelector('[data-statustext]');
      bar.hidden = false;
      fill.style.width = '0%';

      var i = 0;
      text.textContent = PREP_STEPS[0] + '…';
      // kick the bar to full over the whole sequence
      requestAnimationFrame(function () {
        fill.style.transition = 'width ' + (PREP_STEPS.length * PREP_LINE_MS) + 'ms linear';
        fill.style.width = '100%';
      });

      (function nextLine() {
        i++;
        if (i < PREP_STEPS.length) {
          text.textContent = PREP_STEPS[i] + '…';
          setTimeout(nextLine, PREP_LINE_MS);
        } else {
          setTimeout(function () {
            bar.hidden = true;
            btn.classList.remove('is-busy');
            btn.style.visibility = '';
            btn.textContent = 'Read Prep →';
            card.setAttribute('data-prep-state', 'ready');
          }, PREP_LINE_MS);
        }
      })();
    }

    function openDetail(card) {
      card.querySelector('[data-agenda]').hidden = true;
      card.querySelector('[data-detail]').hidden = false;
    }

    function closeDetail(btn) {
      var card = btn.closest('[data-briefing]');
      card.querySelector('[data-detail]').hidden = true;
      card.querySelector('[data-agenda]').hidden = false;
      // button now reads "Read" — reopen without re-running the loading
      var prepBtn = card.querySelector('[data-action="prep"]');
      if (prepBtn) prepBtn.textContent = 'Read';
    }

    function emailPrep(btn) {
      var card = btn.closest('[data-briefing]');
      btn.classList.add('is-busy');
      btn.innerHTML = '<span class="bm-btn-spin"></span>Sending…';
      setTimeout(function () {
        btn.innerHTML = 'Email sent ✓';
        setTimeout(function () {
          card.querySelector('[data-detail]').hidden = true;
          card.querySelector('[data-agenda]').hidden = false;
          // Acme joins the already-prepped meetings
          var prepBtn = card.querySelector('[data-action="prep"]');
          if (prepBtn) prepBtn.hidden = true;
          var chip = card.querySelector('[data-emailed]');
          if (chip) chip.hidden = false;
          card.setAttribute('data-prep-state', 'emailed');
          // reset the detail button for next time the panel is built
          btn.classList.remove('is-busy');
          btn.innerHTML = 'Email me';
        }, 850);
      }, 1050);
    }

    function runSync(btn) {
      btn.classList.add('is-busy');
      var card = btn.closest('.bm-card');
      var fills = card.querySelectorAll('[data-fill]');
      for (var i = 0; i < fills.length; i++) {
        (function (chip, idx) {
          setTimeout(function () {
            chip.textContent = chip.getAttribute('data-value');
            chip.classList.remove('bm-chip-empty');
            chip.classList.add('bm-chip-teal', 'is-filling');
          }, idx * 220);
        })(fills[i], i);
      }
      setTimeout(function () {
        var status = card.querySelector('[data-sync-status]');
        if (status) {
          status.textContent = 'Synced';
          status.classList.remove('bm-chip-amber');
          status.classList.add('bm-chip-teal');
        }
        btn.textContent = 'Synced ✓';
      }, fills.length * 220 + 220);
    }

    function runClear(btn) {
      btn.classList.add('is-busy');
      var card = btn.closest('.bm-card');
      var todos = card.querySelectorAll('[data-todo]');
      var count = card.querySelector('[data-count]');
      for (var i = 0; i < todos.length; i++) {
        (function (todo, idx) {
          setTimeout(function () {
            var check = todo.querySelector('.bm-check');
            if (check) check.classList.add('is-done');
            if (count) count.textContent = (idx + 1) + ' / ' + todos.length;
          }, (idx + 1) * 300);
        })(todos[i], i);
      }
      setTimeout(function () {
        if (count) { count.classList.remove('bm-chip-indigo'); count.classList.add('bm-chip-teal'); }
        btn.textContent = 'Backlog cleared ✓';
      }, todos.length * 300 + 200);
    }
  })();

  // Typewriter for imagine section
  const introEl = document.getElementById('imagine-intro');
  const imagineLines = document.querySelectorAll('#imagine-lines .imagine-line-hidden');
  const plainText = 'You wake up tomorrow and...';
  const finalHTML = 'You wake up <span class="imagine-hl">tomorrow</span> and...';

  function revealLines() {
    imagineLines.forEach((line, i) => {
      setTimeout(() => {
        line.style.opacity = '1';
        line.style.transform = 'translateY(0) scale(1)';
      }, i * 550);
    });
  }

  function runTypewriter() {
    let i = 0;
    const cursor = '<span class="tw-cursor">|</span>';
    const interval = setInterval(() => {
      i++;
      introEl.innerHTML = plainText.slice(0, i) + cursor;
      if (i === plainText.length) {
        clearInterval(interval);
        introEl.innerHTML = finalHTML;
        setTimeout(() => {
          introEl.classList.add('is-gone');
          revealLines();
        }, 1500);
      }
    }, 75);
  }

  const imagineSection = document.getElementById('imagine');
  let twStarted = false;
  const twObserver = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && !twStarted) {
      twStarted = true;
      twObserver.disconnect();
      setTimeout(runTypewriter, 200);
    }
  }, { threshold: 0.3 });
  if (imagineSection) twObserver.observe(imagineSection);

  // Focus email input helper
  function focusEmailInput() {
    const input = document.querySelector('.early-input');
    if (!input) return;
    const ctaSection = document.getElementById('cta');
    ctaSection?.scrollIntoView({ behavior: 'smooth' });
    setTimeout(() => input.focus(), 500);
  }

  document.getElementById('join-waitlist-btn')?.addEventListener('click', focusEmailInput);
  document.querySelector('.btn-cta')?.addEventListener('click', (e) => {
    e.preventDefault();
    focusEmailInput();
  });

  // Burger menu
  const burger = document.getElementById('burger');
  const navLinks = document.getElementById('nav-links');
  burger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = navLinks.classList.toggle('is-open');
    burger.classList.toggle('is-open', open);
    burger.setAttribute('aria-expanded', String(open));
  });
  // Close on link click or outside click
  navLinks?.addEventListener('click', (e) => {
    if (e.target.tagName === 'A') {
      navLinks.classList.remove('is-open');
      burger.classList.remove('is-open');
      burger.setAttribute('aria-expanded', 'false');
    }
  });
  document.addEventListener('click', (e) => {
    if (!burger?.contains(e.target) && !navLinks?.contains(e.target)) {
      navLinks?.classList.remove('is-open');
      burger?.classList.remove('is-open');
      burger?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<script define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
  async function submitEmail(email) {
    if (!supabaseUrl || !supabaseKey) {
      console.error('[waitlist] Supabase config missing — check PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY at build time.');
      return false;
    }
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 15000);
    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/waitlist`, {
        method: 'POST',
        headers: {
          'apikey': supabaseKey,
          'Authorization': `Bearer ${supabaseKey}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({ email }),
        signal: controller.signal,
      });
      if (res.ok || res.status === 201 || res.status === 409) return true;
      const body = await res.text().catch(() => '');
      console.error(`[waitlist] insert failed: ${res.status} ${res.statusText}`, body);
      return false;
    } catch (err) {
      console.error('[waitlist] request failed (network/blocked/timeout):', err);
      return false;
    } finally {
      clearTimeout(timeout);
    }
  }

  const CHECK_SVG = `<svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52"><circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/><path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/></svg>`;

  function wireForm(formId, successId) {
    const form = document.getElementById(formId);
    const success = document.getElementById(successId);
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[type="email"]');
      const btn = form.querySelector('button');
      const email = input.value.trim();
      if (!email) { input.focus(); return; }
      btn.disabled = true;
      btn.textContent = 'Saving...';
      const ok = await submitEmail(email);
      if (ok) {
        input.style.transition = 'opacity 0.3s, width 0.35s, padding 0.35s, margin 0.35s';
        input.style.opacity = '0';
        input.style.width = '0';
        input.style.padding = '0';
        input.style.margin = '0';
        btn.innerHTML = CHECK_SVG;
        btn.classList.add('is-success');
        if (success) {
          setTimeout(() => { success.hidden = false; }, 400);
        }
      } else {
        btn.disabled = false;
        btn.textContent = 'Try again';
      }
    });
  }

  wireForm('form-hero', 'success-hero');
  wireForm('form-cta', 'success-cta');
</script>

<style is:global>
  .checkmark {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: block;
    stroke-width: 2;
    stroke: #fff;
    stroke-miterlimit: 10;
    box-shadow: inset 0px 0px 0px #22c55e;
    animation: checkmark-fill 0.4s ease-in-out 0.4s forwards, checkmark-scale 0.3s ease-in-out 0.9s both;
  }
  .checkmark__circle {
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    stroke-width: 2;
    stroke-miterlimit: 10;
    stroke: #22c55e;
    fill: none;
    animation: checkmark-stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
  }
  .checkmark__check {
    transform-origin: 50% 50%;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: checkmark-stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
  }
  @keyframes checkmark-stroke {
    100% { stroke-dashoffset: 0; }
  }
  @keyframes checkmark-scale {
    0%, 100% { transform: none; }
    50% { transform: scale3d(1.1, 1.1, 1); }
  }
  @keyframes checkmark-fill {
    100% { box-shadow: inset 0px 0px 0px 30px #22c55e; }
  }
</style>
