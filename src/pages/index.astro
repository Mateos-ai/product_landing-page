  /* ── Team ────────────────────────────────────────────────────────────── */
  .team-inner { max-width: 720px; margin: 0 auto; text-align: center; }
  .team-inner h2 { font-size: clamp(1.9rem, 4.2vw, 2.85rem); margin: 12px 0 18px; }
  .team-inner p { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.7; }

  /* ── CTA ─────────────────────────────────────────────────────────────── */
  .cta-section { padding: 100px 0; background: var(--hero-bg); position: relative; overflow: hidden; }
  .cta-inner { position: relative; z-index: 1; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 16px; }
